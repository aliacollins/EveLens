<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EVEMon.Avalonia.Views.Shared.MailReadingWindow"
        Title="EVE Mail"
        Width="600" Height="500"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Header: subject, sender, date -->
        <Border DockPanel.Dock="Top" Padding="12,8"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock x:Name="SubjectText" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource EveAccentPrimaryBrush}"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="SenderText" FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
                <TextBlock x:Name="DateText" FontSize="10"
                           Foreground="{StaticResource EveTextDisabledBrush}" />
            </StackPanel>
        </Border>

        <!-- Body -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="BodyBlock" FontSize="11"
                       Foreground="{StaticResource EveTextPrimaryBrush}"
                       TextWrapping="Wrap" Padding="12" />
        </ScrollViewer>
    </DockPanel>
</Window>
