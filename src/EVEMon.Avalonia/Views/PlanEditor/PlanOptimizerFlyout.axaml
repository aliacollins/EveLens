<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.PlanEditor.PlanOptimizerFlyout">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Padding="10,7"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
            <TextBlock Text="Attribute Optimizer" FontSize="14" FontWeight="Bold"
                       Foreground="{StaticResource EveAccentPrimaryBrush}" />
        </Border>

        <!-- Main content -->
        <ScrollViewer>
            <StackPanel Spacing="12" Margin="16,12">
                <!-- Loading indicator -->
                <TextBlock x:Name="CalculatingText" Text="Calculating optimal attributes..."
                           FontSize="11" Foreground="{StaticResource EveTextSecondaryBrush}"
                           IsVisible="False" />

                <!-- Results panel -->
                <StackPanel x:Name="ResultsPanel" Spacing="8" IsVisible="False">
                    <!-- Time comparison card -->
                    <Border Background="{StaticResource EveBackgroundMediumBrush}"
                            CornerRadius="6" Padding="12">
                        <StackPanel Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Current training time:" FontSize="11"
                                           Foreground="{StaticResource EveTextSecondaryBrush}" />
                                <TextBlock x:Name="CurrentTimeText" Grid.Column="1" FontSize="11"
                                           Foreground="{StaticResource EveTextPrimaryBrush}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Optimized training time:" FontSize="11"
                                           Foreground="{StaticResource EveTextSecondaryBrush}" />
                                <TextBlock x:Name="OptimalTimeText" Grid.Column="1" FontSize="11"
                                           Foreground="{StaticResource EveSuccessGreenBrush}" FontWeight="SemiBold" />
                            </Grid>
                            <Border Height="1" Background="{StaticResource EveBorderBrush}" />
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Time saved:" FontSize="12" FontWeight="Bold"
                                           Foreground="{StaticResource EveTextPrimaryBrush}" />
                                <TextBlock x:Name="TimeSavedText" Grid.Column="1" FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource EveSuccessGreenBrush}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Attribute comparison header -->
                    <TextBlock Text="Attribute Remapping" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource EveAccentPrimaryBrush}" Margin="0,4,0,0" />

                    <!-- 5 attribute rows built in code-behind -->
                    <StackPanel x:Name="AttributeRows" Spacing="4" />

                    <!-- Apply button -->
                    <Button x:Name="ApplyRemapBtn" Content="Apply Remap"
                            FontSize="11" Padding="10,4" CornerRadius="12"
                            HorizontalAlignment="Left" Margin="0,8,0,0"
                            Click="OnApplyRemap" />
                </StackPanel>

                <!-- No plan message -->
                <TextBlock x:Name="NoPlanText"
                           Text="Open a plan to see optimization results."
                           FontSize="11" Foreground="{StaticResource EveTextDisabledBrush}"
                           IsVisible="True" />

                <TextBlock Text="Optimizer tests all 14,641 attribute combinations to find the best distribution for your plan's first year of training."
                           FontSize="10" TextWrapping="Wrap"
                           Foreground="{StaticResource EveTextDisabledBrush}" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
