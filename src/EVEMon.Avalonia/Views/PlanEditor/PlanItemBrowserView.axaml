<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.PlanEditor.PlanItemBrowserView">
    <Grid ColumnDefinitions="300,*">
        <!-- Left panel: Item hierarchy as flat list with depth-based indentation -->
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top" Padding="8,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <ToggleButton x:Name="CanUseToggle" Content="Can Use Only"
                                      FontSize="10" Padding="8,3" CornerRadius="10"
                                      Click="OnCanUseToggled" />
                        <Button Content="Collapse All" FontSize="10" Padding="8,3" CornerRadius="10"
                                Click="OnCollapseAll" />
                    </StackPanel>
                    <Border CornerRadius="12" Background="{StaticResource EveBackgroundDarkestBrush}"
                            BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="1">
                        <DockPanel>
                            <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                    Content="&#x2715;" FontSize="9"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,3" CornerRadius="0,12,12,0"
                                    IsVisible="False" Click="OnClearFilter" />
                            <TextBox x:Name="FilterBox" Watermark="Search items..."
                                     FontSize="10" Padding="8,4"
                                     Background="Transparent" BorderThickness="0"
                                     TextChanged="OnFilterChanged" />
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="TreeList" HorizontalAlignment="Stretch">
                    <ItemsControl.Styles>
                        <Style Selector="ItemsControl > ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Panel>
                                <!-- Category node -->
                                <Border IsVisible="{Binding IsCategory}" Classes="group-header"
                                        Margin="{Binding IndentMargin}"
                                        PointerPressed="OnNodeToggle">
                                    <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
                                        <TextBlock Grid.Column="0" Text="{Binding Chevron}"
                                                   FontSize="11" Width="16"
                                                   Foreground="{StaticResource EveTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{Binding NameBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}"
                                                   FontSize="10" Foreground="{StaticResource EveTextSecondaryBrush}"
                                                   Margin="8,0" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <!-- Leaf item -->
                                <Border IsVisible="{Binding IsLeaf}" Classes="item-row"
                                        Margin="{Binding IndentMargin}" Padding="4,3,8,3"
                                        Background="{StaticResource EveBackgroundDarkBrush}"
                                        BorderBrush="{StaticResource EveBorderBrush}"
                                        BorderThickness="0,0,0,1" HorizontalAlignment="Stretch"
                                        PointerPressed="OnItemClicked">
                                    <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11"
                                                   Foreground="{Binding NameBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                                                   FontSize="10" Foreground="{Binding StatusBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- Right panel: Item detail + properties -->
        <Border Grid.Column="1" BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DetailPanel" Margin="16,12" Spacing="10" IsVisible="False">
                    <TextBlock x:Name="DetailName" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource EveAccentPrimaryBrush}" />
                    <TextBlock x:Name="DetailSlot" FontSize="11"
                               Foreground="{StaticResource EveTextSecondaryBrush}" />
                    <TextBlock x:Name="DetailDescription" FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource EveTextSecondaryBrush}"
                               MaxHeight="100" />
                    <Border Height="1" Background="{StaticResource EveBorderBrush}" Margin="0,4" />
                    <TextBlock Text="Required Skills:" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource EveTextPrimaryBrush}" />
                    <StackPanel x:Name="PrereqsList" Spacing="2" />
                    <Button x:Name="PlanToUseBtn" Content="Plan to Use" FontSize="11"
                            Padding="12,5" CornerRadius="12" Margin="0,8,0,0"
                            Click="OnPlanToUse" IsVisible="False" />
                    <!-- Properties section -->
                    <Border x:Name="PropertiesDivider" Height="1" Background="{StaticResource EveBorderBrush}"
                            Margin="0,4" IsVisible="False" />
                    <TextBlock x:Name="PropertiesHeader" Text="Properties:" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource EveTextPrimaryBrush}" IsVisible="False" />
                    <StackPanel x:Name="PropertiesList" Spacing="8" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
