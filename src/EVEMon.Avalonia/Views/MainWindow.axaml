<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EVEMon.Avalonia.Views.CharacterMonitor"
        x:Class="EVEMon.Avalonia.Views.MainWindow"
        Title="EVEMon"
        Width="1024" Height="768">

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem x:Name="AddCharMenuItem" Header="_Add Character..." />
                <MenuItem x:Name="ManageCharsMenuItem" Header="_Manage Characters..." />
                <Separator />
                <MenuItem x:Name="ExitMenuItem" Header="E_xit" />
            </MenuItem>
            <MenuItem Header="_Plans">
                <MenuItem x:Name="NewPlanMenuItem" Header="_New Plan..." />
                <MenuItem x:Name="ManagePlansMenuItem" Header="Ma_nage Plans..." />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem x:Name="CharCompMenuItem" Header="_Character Comparison..." />
                <Separator />
                <MenuItem x:Name="SettingsMenuItem" Header="_Settings..." />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem x:Name="UserGuideMenuItem" Header="_User Guide" />
                <MenuItem x:Name="ReportIssueMenuItem" Header="_Report Issue..." />
                <Separator />
                <MenuItem x:Name="AboutMenuItem" Header="_About EVEMon" />
            </MenuItem>
        </Menu>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="8,3"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="EveTimeText" Text="EVE Time: --:--" FontSize="11"
                           Foreground="{StaticResource EveAccentSecondaryBrush}" />
                <TextBlock Text="  |  " FontSize="11" Foreground="{StaticResource EveTextDisabledBrush}" />
                <TextBlock x:Name="ServerStatusText" Text="Server: Unknown" FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
                <TextBlock DockPanel.Dock="Right" x:Name="NotificationCountText"
                           Text="" FontSize="11" HorizontalAlignment="Right"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </DockPanel>
        </Border>

        <!-- Tabs: Overview + Characters (built in code-behind) -->
        <TabControl x:Name="MainTabControl" Padding="0" Margin="0" />
    </DockPanel>
</Window>
