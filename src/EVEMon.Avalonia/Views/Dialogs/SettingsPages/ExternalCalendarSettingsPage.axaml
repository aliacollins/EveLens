<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.ExternalCalendarSettingsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Margin="0,0,12,0">
            <TextBlock Text="External Calendar" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

            <CheckBox x:Name="EnabledCheckBox" Content="Enable external calendar integration" />

            <Separator Margin="0,4" />

            <StackPanel x:Name="CalendarOptionsPanel" Spacing="10">
                <TextBlock Text="Calendar Provider" FontWeight="SemiBold" />
                <StackPanel Spacing="6" Margin="8,0,0,0">
                    <RadioButton x:Name="GoogleRadio" Content="Google Calendar" GroupName="CalendarProvider" />
                    <RadioButton x:Name="OutlookRadio" Content="Microsoft Outlook" GroupName="CalendarProvider" />
                </StackPanel>

                <Separator Margin="0,4" />

                <!-- Google-specific options -->
                <StackPanel x:Name="GooglePanel" Spacing="6">
                    <TextBlock Text="Google Calendar Settings" FontWeight="SemiBold" />
                    <StackPanel Spacing="6" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Calendar Name:" VerticalAlignment="Center" Width="130" />
                            <TextBox x:Name="GoogleCalNameTextBox" Width="200" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Event Reminder:" VerticalAlignment="Center" Width="130" />
                            <ComboBox x:Name="GoogleReminderCombo" Width="120">
                                <ComboBoxItem Content="Email" />
                                <ComboBoxItem Content="Pop-up" />
                                <ComboBoxItem Content="SMS" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Outlook-specific options -->
                <StackPanel x:Name="OutlookPanel" Spacing="6">
                    <TextBlock Text="Outlook Calendar Settings" FontWeight="SemiBold" />
                    <StackPanel Spacing="6" Margin="8,0,0,0">
                        <CheckBox x:Name="OutlookDefaultCalCheckBox" Content="Use Outlook default calendar" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Custom Calendar Path:" VerticalAlignment="Center" Width="130" />
                            <TextBox x:Name="OutlookCalPathTextBox" Width="200" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Separator Margin="0,4" />

                <TextBlock Text="Reminders" FontWeight="SemiBold" />
                <StackPanel Spacing="6" Margin="8,0,0,0">
                    <CheckBox x:Name="UseRemindingCheckBox" Content="Enable reminders" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Reminder interval (minutes):" VerticalAlignment="Center" />
                        <NumericUpDown x:Name="RemindingInterval" Minimum="1" Maximum="120" Value="10" Width="80" />
                    </StackPanel>

                    <CheckBox x:Name="UseAltRemindingCheckBox" Content="Use alternate reminding times" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Early reminder:" VerticalAlignment="Center" Width="100" />
                        <TimePicker x:Name="EarlyTimePicker" ClockIdentifier="24HourClock" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Late reminder:" VerticalAlignment="Center" Width="100" />
                        <TimePicker x:Name="LateTimePicker" ClockIdentifier="24HourClock" />
                    </StackPanel>
                </StackPanel>

                <Separator Margin="0,4" />

                <CheckBox x:Name="LastQueuedSkillOnlyCheckBox" Content="Export last queued skill only" />
            </StackPanel>

            <TextBlock Text="Note: Calendar push functionality requires platform-specific integration and may not work in all environments."
                       TextWrapping="Wrap" FontSize="11" Foreground="Gray" Margin="0,8,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
