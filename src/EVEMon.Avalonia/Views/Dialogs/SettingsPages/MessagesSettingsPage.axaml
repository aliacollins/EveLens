<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.MessagesSettingsPage">

    <StackPanel Spacing="12">
        <TextBlock Text="Skill Planner Messages" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

        <TextBlock Text="Obsolete Plan Entry Removal" FontWeight="SemiBold" />
        <TextBlock Text="When skills in your plan have already been trained, EVEMon can handle them automatically."
                   TextWrapping="Wrap" FontSize="12" Foreground="Gray" Margin="0,0,0,4" />

        <StackPanel Spacing="6" Margin="8,0,0,0">
            <RadioButton x:Name="AlwaysAskRadio" Content="Always ask" GroupName="ObsoleteRemoval" />
            <RadioButton x:Name="RemoveConfirmedRadio"
                         Content="Remove completed (confirmed by API) entries only"
                         GroupName="ObsoleteRemoval" />
            <RadioButton x:Name="RemoveAllRadio" Content="Remove all completed entries" GroupName="ObsoleteRemoval" />
        </StackPanel>
    </StackPanel>
</UserControl>
