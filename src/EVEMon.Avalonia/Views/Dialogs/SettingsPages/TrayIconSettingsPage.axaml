<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.TrayIconSettingsPage">

    <StackPanel Spacing="12">
        <TextBlock Text="System Tray Icon" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

        <TextBlock Text="Tray Icon Behaviour" FontWeight="SemiBold" />
        <StackPanel Spacing="6" Margin="8,0,0,0">
            <RadioButton x:Name="TrayDisabledRadio" Content="Disabled" GroupName="TrayBehaviour" />
            <RadioButton x:Name="TrayMinimizedRadio" Content="Show when minimized" GroupName="TrayBehaviour" />
            <RadioButton x:Name="TrayAlwaysRadio" Content="Always visible" GroupName="TrayBehaviour" />
        </StackPanel>

        <Separator Margin="0,4" />

        <TextBlock Text="Main Window Close Behaviour" FontWeight="SemiBold" />
        <StackPanel Spacing="6" Margin="8,0,0,0">
            <RadioButton x:Name="CloseExitRadio" Content="Exit the application" GroupName="CloseBehaviour" />
            <RadioButton x:Name="CloseMinTrayRadio" Content="Minimize to system tray" GroupName="CloseBehaviour" />
            <RadioButton x:Name="CloseMinTaskbarRadio" Content="Minimize to taskbar" GroupName="CloseBehaviour" />
        </StackPanel>

        <Separator Margin="0,4" />

        <TextBlock Text="Tray Popup Style" FontWeight="SemiBold" />
        <StackPanel Spacing="6" Margin="8,0,0,0">
            <RadioButton x:Name="PopupFormRadio" Content="Popup form" GroupName="PopupStyle" />
            <RadioButton x:Name="PopupTooltipRadio" Content="Windows tooltip" GroupName="PopupStyle" />
            <RadioButton x:Name="PopupDisabledRadio" Content="Disabled" GroupName="PopupStyle" />
        </StackPanel>
    </StackPanel>
</UserControl>
