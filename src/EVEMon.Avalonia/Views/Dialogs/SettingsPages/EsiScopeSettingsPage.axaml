<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.EsiScopeSettingsPage">

    <StackPanel Spacing="12">
        <TextBlock Text="ESI Scopes" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

        <TextBlock Text="Select which ESI API scopes EVEMon will request when authenticating with EVE Online. Reducing scopes limits which features are available but may improve privacy."
                   TextWrapping="Wrap" FontSize="12" Foreground="Gray" />

        <Separator Margin="0,4" />

        <TextBlock Text="Scope Preset" FontWeight="SemiBold" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Preset:" VerticalAlignment="Center" />
            <ComboBox x:Name="PresetCombo" Width="240" />
        </StackPanel>

        <TextBlock x:Name="PresetDescription"
                   Text=""
                   TextWrapping="Wrap"
                   FontSize="12"
                   Foreground="Gray"
                   Margin="0,0,0,4" />

        <Button x:Name="CustomizeScopesButton"
                Content="Customize Scopes..."
                HorizontalAlignment="Left"
                Padding="10,4"
                CornerRadius="12" />

        <Separator Margin="0,4" />

        <TextBlock Text="Note: Changes to ESI scopes take effect the next time you authenticate a character. Existing characters will continue using their current scopes until re-authenticated."
                   TextWrapping="Wrap" FontSize="11" Foreground="Gray" />
    </StackPanel>
</UserControl>
