<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.SchedulerSettingsPage">

    <StackPanel Spacing="12">
        <TextBlock Text="Scheduler Colors" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

        <TextBlock Text="Customize the colors used in the scheduler calendar display."
                   TextWrapping="Wrap" FontSize="12" Foreground="Gray" />

        <Separator Margin="0,4" />

        <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Text Color:" VerticalAlignment="Center" Width="160" />
                <Border x:Name="TextColorPreview" Width="20" Height="20" CornerRadius="3"
                        BorderBrush="Gray" BorderThickness="1" />
                <TextBox x:Name="TextColorHex" Width="80" FontSize="11" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Blocking Color:" VerticalAlignment="Center" Width="160" />
                <Border x:Name="BlockingColorPreview" Width="20" Height="20" CornerRadius="3"
                        BorderBrush="Gray" BorderThickness="1" />
                <TextBox x:Name="BlockingColorHex" Width="80" FontSize="11" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Recurring Event Start:" VerticalAlignment="Center" Width="160" />
                <Border x:Name="RecurStartColorPreview" Width="20" Height="20" CornerRadius="3"
                        BorderBrush="Gray" BorderThickness="1" />
                <TextBox x:Name="RecurStartColorHex" Width="80" FontSize="11" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Recurring Event End:" VerticalAlignment="Center" Width="160" />
                <Border x:Name="RecurEndColorPreview" Width="20" Height="20" CornerRadius="3"
                        BorderBrush="Gray" BorderThickness="1" />
                <TextBox x:Name="RecurEndColorHex" Width="80" FontSize="11" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Single Event Start:" VerticalAlignment="Center" Width="160" />
                <Border x:Name="SimpleStartColorPreview" Width="20" Height="20" CornerRadius="3"
                        BorderBrush="Gray" BorderThickness="1" />
                <TextBox x:Name="SimpleStartColorHex" Width="80" FontSize="11" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Single Event End:" VerticalAlignment="Center" Width="160" />
                <Border x:Name="SimpleEndColorPreview" Width="20" Height="20" CornerRadius="3"
                        BorderBrush="Gray" BorderThickness="1" />
                <TextBox x:Name="SimpleEndColorHex" Width="80" FontSize="11" />
            </StackPanel>
        </StackPanel>

        <TextBlock Text="Enter colors as hex values (#RRGGBB)."
                   FontSize="11" Foreground="Gray" Margin="0,4,0,0" />
    </StackPanel>
</UserControl>
