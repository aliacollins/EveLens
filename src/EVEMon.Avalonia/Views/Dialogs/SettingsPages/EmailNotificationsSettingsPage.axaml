<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.EmailNotificationsSettingsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="12" Margin="0,0,12,0">
            <TextBlock Text="Skill Completion Mails" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

            <CheckBox x:Name="SendMailCheckBox" Content="Send email when skill training completes" />

            <Separator Margin="0,4" />

            <StackPanel x:Name="MailOptionsPanel" Spacing="10">
                <TextBlock Text="SMTP Server" FontWeight="SemiBold" />
                <StackPanel Spacing="6" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Provider:" VerticalAlignment="Center" Width="120" />
                        <ComboBox x:Name="ProviderCombo" Width="160">
                            <ComboBoxItem Content="Gmail" />
                            <ComboBoxItem Content="Outlook" />
                            <ComboBoxItem Content="Yahoo" />
                            <ComboBoxItem Content="Custom" />
                            <ComboBoxItem Content="Default" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="SMTP Server:" VerticalAlignment="Center" Width="120" />
                        <TextBox x:Name="SmtpServerTextBox" Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Port:" VerticalAlignment="Center" Width="120" />
                        <NumericUpDown x:Name="PortNumber" Minimum="1" Maximum="65535" Value="25" Width="100" />
                    </StackPanel>
                    <CheckBox x:Name="RequiresSslCheckBox" Content="Server requires SSL/TLS" />
                </StackPanel>

                <Separator Margin="0,4" />

                <TextBlock Text="Authentication" FontWeight="SemiBold" />
                <StackPanel Spacing="6" Margin="8,0,0,0">
                    <CheckBox x:Name="AuthRequiredCheckBox" Content="Server requires authentication" />
                    <StackPanel x:Name="AuthPanel" Spacing="6" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Username:" VerticalAlignment="Center" Width="80" />
                            <TextBox x:Name="AuthUserTextBox" Width="200" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Password:" VerticalAlignment="Center" Width="80" />
                            <TextBox x:Name="AuthPasswordTextBox" Width="200" PasswordChar="&#x25CF;" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <Separator Margin="0,4" />

                <TextBlock Text="Email Addresses" FontWeight="SemiBold" />
                <StackPanel Spacing="6" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="From:" VerticalAlignment="Center" Width="80" />
                        <TextBox x:Name="FromAddressTextBox" Width="200" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="To:" VerticalAlignment="Center" Width="80" />
                        <TextBox x:Name="ToAddressTextBox" Width="200" />
                    </StackPanel>
                </StackPanel>

                <Separator Margin="0,4" />

                <CheckBox x:Name="ShortFormatCheckBox" Content="Use short email format" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
