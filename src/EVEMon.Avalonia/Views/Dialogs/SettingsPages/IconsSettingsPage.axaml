<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.IconsSettingsPage">

    <StackPanel Spacing="12">
        <TextBlock Text="Skill Planner Icons" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

        <TextBlock Text="Select the icon set used in the skill planner tree views."
                   TextWrapping="Wrap" FontSize="12" Foreground="Gray" />

        <Separator Margin="0,4" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Icon Set:" VerticalAlignment="Center" />
            <ComboBox x:Name="IconSetCombo" Width="160">
                <ComboBoxItem Content="Default" />
                <ComboBoxItem Content="Set 2" />
                <ComboBoxItem Content="Set 3" />
            </ComboBox>
        </StackPanel>

        <TextBlock Text="Icon preview is only available in the WinForms client."
                   FontSize="13" Foreground="Gray" TextWrapping="Wrap" Margin="0,8,0,0" />
    </StackPanel>
</UserControl>
