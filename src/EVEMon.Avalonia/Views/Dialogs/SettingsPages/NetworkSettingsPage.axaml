<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.NetworkSettingsPage">

    <StackPanel Spacing="12">
        <TextBlock Text="Network" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

        <!-- Proxy Server -->
        <TextBlock Text="Proxy Server" FontWeight="SemiBold" />
        <CheckBox x:Name="UseProxyCheckBox"
                  Content="Use custom proxy" />

        <StackPanel x:Name="ProxyPanel" Spacing="8" Margin="20,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Host:" VerticalAlignment="Center" Width="40" />
                <TextBox x:Name="ProxyHostTextBox" Width="200" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Port:" VerticalAlignment="Center" Width="40" />
                <TextBox x:Name="ProxyPortTextBox" Width="80" />
            </StackPanel>
        </StackPanel>

        <Separator Margin="0,4" />

        <!-- ESI Settings -->
        <TextBlock Text="ESI Settings" FontWeight="SemiBold" />
        <StackPanel Spacing="8" Margin="0,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Client ID:" VerticalAlignment="Center" Width="80" />
                <TextBox x:Name="ClientIdTextBox" Width="280" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Client Secret:" VerticalAlignment="Center" Width="80" />
                <TextBox x:Name="ClientSecretTextBox" Width="280"
                         PasswordChar="*" />
            </StackPanel>
            <Button x:Name="UseDefaultCredentialsButton"
                    Content="Use Default"
                    HorizontalAlignment="Left"
                    CornerRadius="12" Padding="10,4" FontSize="11"
                    ToolTip.Tip="Clear custom credentials and use the built-in EVEMon defaults" />
        </StackPanel>
    </StackPanel>
</UserControl>
