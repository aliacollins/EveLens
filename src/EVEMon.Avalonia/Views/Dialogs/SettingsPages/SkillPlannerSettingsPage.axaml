<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.SkillPlannerSettingsPage">

    <StackPanel Spacing="12">
        <TextBlock Text="Skill Planner" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

        <!-- Highlighting -->
        <TextBlock Text="Highlighting" FontWeight="SemiBold" />
        <StackPanel Spacing="6" Margin="8,0,0,0">
            <CheckBox x:Name="HighlightPlannedSkillsCheckBox"
                      Content="Highlight Planned Skills" />
            <CheckBox x:Name="HighlightPrerequisitesCheckBox"
                      Content="Highlight Prerequisites" />
            <CheckBox x:Name="HighlightConflictsCheckBox"
                      Content="Highlight Schedule Conflicts" />
            <CheckBox x:Name="HighlightPartialSkillsCheckBox"
                      Content="Highlight Partially Trained Skills" />
            <CheckBox x:Name="HighlightQueuedSkillsCheckBox"
                      Content="Highlight Queued Skills" />
        </StackPanel>

        <Separator Margin="0,4" />

        <!-- Plan Options -->
        <TextBlock Text="Plan Options" FontWeight="SemiBold" />
        <StackPanel Spacing="6" Margin="8,0,0,0">
            <CheckBox x:Name="SummaryOnMultiSelectCheckBox"
                      Content="Show Plan Summary Only On &quot;Multi-Select&quot;" />
            <CheckBox x:Name="AdvanceEntryAddCheckBox"
                      Content="Set Priority When Adding Skills To Plan" />
        </StackPanel>

        <Separator Margin="0,4" />

        <!-- Obsolete Entry Removal -->
        <TextBlock Text="Obsolete Plan Entry Removal" FontWeight="SemiBold" />
        <StackPanel Spacing="6" Margin="8,0,0,0">
            <RadioButton x:Name="AlwaysAskRadio"
                         Content="Always ask"
                         GroupName="ObsoleteRemoval" />
            <RadioButton x:Name="RemoveAllRadio"
                         Content="Remove all"
                         GroupName="ObsoleteRemoval" />
            <RadioButton x:Name="RemoveConfirmedRadio"
                         Content="Remove confirmed"
                         GroupName="ObsoleteRemoval" />
        </StackPanel>
    </StackPanel>
</UserControl>
