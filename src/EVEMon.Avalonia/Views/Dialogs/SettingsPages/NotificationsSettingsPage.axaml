<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.NotificationsSettingsPage">

    <StackPanel Spacing="12">
        <TextBlock Text="Notifications" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

        <CheckBox x:Name="PlaySoundOnSkillCompleteCheckBox"
                  Content="Play sound when skill training completes" />

        <Separator Margin="0,4" />

        <TextBlock Text="Notification categories and behaviors will be configurable in a future update."
                   FontSize="13"
                   Foreground="Gray"
                   TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
