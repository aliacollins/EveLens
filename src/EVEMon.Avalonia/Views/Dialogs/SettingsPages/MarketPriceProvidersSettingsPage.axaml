<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.MarketPriceProvidersSettingsPage">

    <StackPanel Spacing="12">
        <TextBlock Text="Market Price Providers" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

        <TextBlock Text="Select the market data provider used for item price lookups."
                   TextWrapping="Wrap" FontSize="12" Foreground="Gray" />

        <Separator Margin="0,4" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Price Provider:" VerticalAlignment="Center" />
            <ComboBox x:Name="ProviderCombo" Width="200" />
        </StackPanel>
    </StackPanel>
</UserControl>
