<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.Dialogs.SettingsPages.UpdatesSettingsPage">

    <StackPanel Spacing="12">
        <TextBlock Text="Updates" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />

        <CheckBox x:Name="CheckForUpdatesCheckBox"
                  Content="Check for EVEMon updates" />

        <CheckBox x:Name="CheckTimeCheckBox"
                  Content="Check system clock sync" />
    </StackPanel>
</UserControl>
