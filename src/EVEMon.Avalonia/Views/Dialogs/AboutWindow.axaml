<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EVEMon.Avalonia.Views.Dialogs.AboutWindow"
        Title="About EVEMon NexT"
        Width="720" Height="680"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <DockPanel>

        <!-- Header section -->
        <Border DockPanel.Dock="Top" Padding="24,20,24,0">
            <DockPanel>
                <!-- App icon -->
                <Border DockPanel.Dock="Left" Width="56" Height="56" CornerRadius="14"
                        Margin="0,0,20,0" VerticalAlignment="Top"
                        Background="{StaticResource EveBackgroundMediumBrush}"
                        BorderThickness="1" BorderBrush="{StaticResource EveAccentDimmedBrush}">
                    <Panel>
                        <TextBlock Text="EM" FontSize="11" FontWeight="ExtraBold"
                                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                                   LetterSpacing="0.5"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Border Background="{StaticResource EveAccentSecondaryBrush}"
                                CornerRadius="3" Padding="4,1"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,-2,-2">
                            <TextBlock Text="NxT" FontSize="7" FontWeight="Bold"
                                       Foreground="{StaticResource EveBackgroundDarkestBrush}" />
                        </Border>
                    </Panel>
                </Border>

                <!-- Title and info -->
                <StackPanel VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="EVEMon " FontSize="20" FontWeight="Light"
                                   Foreground="{StaticResource EveTextPrimaryBrush}" />
                        <TextBlock Text="NexT" FontSize="20" FontWeight="Bold"
                                   FontStyle="Italic"
                                   Foreground="{StaticResource EveTextPrimaryBrush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <TextBlock x:Name="VersionText" FontSize="11"
                                   Foreground="{StaticResource EveTextDisabledBrush}" />
                        <TextBlock Text="." FontSize="10"
                                   Foreground="{StaticResource EveTextDisabledBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=".NET 8 . Avalonia" FontSize="11"
                                   Foreground="{StaticResource EveTextSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock Text="Character intelligence for EVE Online. Built on 20 years of community work."
                               FontSize="11" Foreground="{StaticResource EveTextSecondaryBrush}"
                               Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Tab bar -->
        <Border DockPanel.Dock="Top" Padding="24,12,24,0"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel x:Name="TabBar" Orientation="Horizontal" Spacing="4" />
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Padding="24,8"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0"
                Background="{StaticResource EveBackgroundMediumBrush}">
            <DockPanel>
                <TextBlock Text="EVE Online and all related logos are trademarks of CCP hf."
                           FontSize="10" Foreground="{StaticResource EveTextDisabledBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="Fly safe. o7" FontSize="10"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Right" DockPanel.Dock="Right"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Close button -->
        <Border DockPanel.Dock="Bottom" Padding="24,10">
            <Button x:Name="OkButton" Content="Close"
                    FontSize="11" Padding="20,6" CornerRadius="12"
                    HorizontalAlignment="Right" />
        </Border>

        <!-- Tab content area (no scroll — window is large enough) -->
        <Border Padding="24,16,24,8">
            <Panel x:Name="TabContent" />
        </Border>

    </DockPanel>
</Window>
