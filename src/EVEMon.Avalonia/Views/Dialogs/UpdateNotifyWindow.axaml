<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EVEMon.Avalonia.Views.Dialogs.UpdateNotifyWindow"
        Title="Update Available"
        Width="500" Height="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <DockPanel Margin="20">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="Update Available"
                   FontSize="15" FontWeight="Bold"
                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                   Margin="0,0,0,12" />

        <!-- Version line -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,12">
            <TextBlock x:Name="CurrentVersionText" FontSize="12"
                       Foreground="{StaticResource EveTextSecondaryBrush}" />
            <TextBlock Text="&#x2192;" FontSize="12"
                       Foreground="{StaticResource EveTextDisabledBrush}" />
            <TextBlock x:Name="NewVersionText" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource EveSuccessGreenBrush}" />
        </StackPanel>

        <!-- Separator -->
        <Border DockPanel.Dock="Top" Height="1"
                Background="{StaticResource EveBorderBrush}" Margin="0,0,0,12" />

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="6" Margin="0,12,0,0">
            <Button x:Name="SkipBtn" Content="Skip This Version"
                    FontSize="11" Padding="10,4" CornerRadius="12"
                    Foreground="{StaticResource EveTextDisabledBrush}" />
            <Button x:Name="RemindBtn" Content="Remind Me Later"
                    FontSize="11" Padding="10,4" CornerRadius="12" />
            <Button x:Name="DownloadBtn" Content="Download &amp; Install"
                    FontSize="11" Padding="10,4" CornerRadius="12"
                    Foreground="{StaticResource EveAccentPrimaryBrush}" />
        </StackPanel>

        <!-- Release notes -->
        <StackPanel Spacing="4">
            <TextBlock Text="Release Notes" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource EveAccentPrimaryBrush}" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ReleaseNotesPanel" Spacing="0" />
            </ScrollViewer>
        </StackPanel>

    </DockPanel>
</Window>
