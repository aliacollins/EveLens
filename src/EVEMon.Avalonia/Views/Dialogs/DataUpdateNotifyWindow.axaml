<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EVEMon.Avalonia.Views.Dialogs.DataUpdateNotifyWindow"
        Title="Game Data Update Available"
        Width="460" Height="320"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <DockPanel Margin="20">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top" Text="Game Data Update Available"
                   FontSize="15" FontWeight="Bold"
                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                   Margin="0,0,0,8" />

        <TextBlock DockPanel.Dock="Top" FontSize="11"
                   Foreground="{StaticResource EveTextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,12"
                   Text="Updated game data files are available. Updating will download the new files and restart the application." />

        <!-- Separator -->
        <Border DockPanel.Dock="Top" Height="1"
                Background="{StaticResource EveBorderBrush}" Margin="0,0,0,12" />

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="6" Margin="0,12,0,0">
            <Button x:Name="RemindBtn" Content="Remind Me Later"
                    FontSize="11" Padding="10,4" CornerRadius="12" />
            <Button x:Name="UpdateBtn" Content="Update &amp; Restart"
                    FontSize="11" Padding="10,4" CornerRadius="12"
                    Foreground="{StaticResource EveAccentPrimaryBrush}" />
        </StackPanel>

        <!-- Changed files list -->
        <StackPanel Spacing="4">
            <TextBlock Text="Changed Files" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource EveAccentPrimaryBrush}" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="FilesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="8,2">
                                <TextBlock Text="&#x2022;" FontSize="11"
                                           Foreground="{StaticResource EveTextDisabledBrush}" />
                                <TextBlock Text="{Binding}" FontSize="11"
                                           Foreground="{StaticResource EveTextPrimaryBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

    </DockPanel>
</Window>
