<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.CharacterMonitor.CharacterContactsView">

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Contacts is not enabled for this character."
                           FontSize="12"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enable this to start fetching data from EVE Online."
                           FontSize="11"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Enable Contacts"
                        FontSize="11" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Padding="10,7"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- Right side: group selector -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <TextBlock Text="Group by:" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{StaticResource EveTextSecondaryBrush}" />
                        <ComboBox x:Name="GroupByCombo" FontSize="11" Padding="8,3"
                                  MinWidth="140" SelectedIndex="0"
                                  SelectionChanged="OnGroupByChanged">
                            <ComboBoxItem Content="No group" />
                            <ComboBoxItem Content="Contact Group" />
                            <ComboBoxItem Content="Standing Bracket" />
                        </ComboBox>
                    </StackPanel>

                    <!-- Left side: search with clear -->
                    <Border CornerRadius="14"
                            Background="{StaticResource EveBackgroundDarkestBrush}"
                            BorderBrush="{StaticResource EveBorderBrush}"
                            BorderThickness="1" Padding="0"
                            MinWidth="240" MaxWidth="320">
                        <DockPanel>
                            <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                    Content="&#x2715;" FontSize="10"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="8,4" CornerRadius="0,14,14,0"
                                    Click="OnClearFilter"
                                    IsVisible="False" />
                            <TextBox x:Name="FilterBox"
                                     Watermark="Search contacts..."
                                     FontSize="11" Padding="10,5"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextChanged="OnFilterChanged" />
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Padding="10,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText" Text="Contacts: 0" FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </Border>

            <!-- Dense DataGrid -->
            <DataGrid x:Name="ContactsGrid" Classes="plan-grid"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True" CanUserReorderColumns="True" CanUserSortColumns="True"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      Background="{StaticResource EveBackgroundDarkBrush}"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource EveBorderBrush}"
                      SelectionMode="Extended">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy Name" Click="OnCopyName" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <!-- Name -->
                    <DataGridTemplateColumn Header="NAME" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource EveAccentPrimaryBrush}"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Standing -->
                    <DataGridTemplateColumn Header="STANDING" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StandingText}" FontSize="10"
                                           Foreground="{Binding StandingBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right"
                                           Margin="0,0,6,0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Watchlist -->
                    <DataGridTemplateColumn Header="WATCH" Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding WatchlistText}" FontSize="10"
                                           Foreground="{StaticResource EveWarningYellowBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Group -->
                    <DataGridTemplateColumn Header="GROUP" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding GroupName}" FontSize="10"
                                           Foreground="{StaticResource EveTextDisabledBrush}"
                                           VerticalAlignment="Center" Margin="4,0,0,0"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Panel>
</UserControl>
