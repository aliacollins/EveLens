<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.CharacterMonitor.CharacterContactsView">

    <Panel>
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Contacts is not enabled for this character."
                           FontSize="12" Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enable this to start fetching data from EVE Online."
                           FontSize="11" Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Enable Contacts"
                        FontSize="11" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center" Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Padding="10,7"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <TextBlock Text="Group by:" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{StaticResource EveTextSecondaryBrush}" />
                        <ComboBox x:Name="GroupByCombo" FontSize="11" Padding="8,3"
                                  MinWidth="140" SelectedIndex="0"
                                  SelectionChanged="OnGroupByChanged">
                            <ComboBoxItem Content="No group" />
                            <ComboBoxItem Content="Contact Group" />
                            <ComboBoxItem Content="Standing Bracket" />
                        </ComboBox>
                        <Button Content="Collapse All" FontSize="11" Padding="10,4"
                                CornerRadius="12" Click="OnCollapseAll" />
                        <Button Content="Expand All" FontSize="11" Padding="10,4"
                                CornerRadius="12" Click="OnExpandAll" />
                    </StackPanel>

                    <Border CornerRadius="14"
                            Background="{StaticResource EveBackgroundDarkestBrush}"
                            BorderBrush="{StaticResource EveBorderBrush}"
                            BorderThickness="1" Padding="0"
                            MinWidth="240" MaxWidth="320">
                        <DockPanel>
                            <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                    Content="&#x2715;" FontSize="10"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="8,4" CornerRadius="0,14,14,0"
                                    Click="OnClearFilter" IsVisible="False" />
                            <TextBox x:Name="FilterBox" Watermark="Search contacts..."
                                     FontSize="11" Padding="10,5"
                                     Background="Transparent" BorderThickness="0"
                                     TextChanged="OnFilterChanged" />
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Padding="10,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText" Text="Contacts: 0" FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </Border>

            <!-- Grouped contacts (same Expander pattern as Standings) -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ContactGroupsList" Margin="0" HorizontalAlignment="Stretch">
                    <ItemsControl.Styles>
                        <Style Selector="ItemsControl > ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Border Classes="group-header" HorizontalAlignment="Stretch"
                                        PointerPressed="OnGroupHeaderClicked">
                                    <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
                                        <TextBlock Grid.Column="0" Text="{Binding Chevron}"
                                                   FontSize="11" Width="16"
                                                   Foreground="{StaticResource EveTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource EveTextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="8,0" />
                                    </Grid>
                                </Border>

                                <ItemsControl ItemsSource="{Binding Contacts}"
                                              HorizontalAlignment="Stretch"
                                              IsVisible="{Binding IsExpanded}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="item-row" Padding="20,4,10,4"
                                                    Background="{StaticResource EveBackgroundDarkBrush}"
                                                    BorderBrush="{StaticResource EveBorderBrush}"
                                                    BorderThickness="0,0,0,0.5"
                                                    HorizontalAlignment="Stretch">
                                                <Grid ColumnDefinitions="*,Auto,Auto"
                                                      HorizontalAlignment="Stretch">
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                               FontSize="11"
                                                               Foreground="{Binding NameBrush}"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding StandingText}"
                                                               FontSize="11" Foreground="{Binding StandingBrush}"
                                                               VerticalAlignment="Center"
                                                               MinWidth="50" TextAlignment="Right"
                                                               Margin="8,0" />
                                                    <TextBlock Grid.Column="2" Text="{Binding WatchlistText}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource EveWarningYellowBrush}"
                                                               VerticalAlignment="Center"
                                                               MinWidth="20" TextAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Panel>
</UserControl>
