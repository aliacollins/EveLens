<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.CharacterMonitor.CharacterSkillsView">

    <DockPanel>
        <!-- Top bar: filter + actions -->
        <Border DockPanel.Dock="Top" Padding="10,7"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Right side: toggle -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <ToggleButton x:Name="ShowAllToggle" FontSize="11" Padding="10,4"
                                  Content="Trained Only" IsChecked="False"
                                  CornerRadius="12"
                                  Click="OnToggleShowAll" />
                </StackPanel>

                <!-- Left side: search with clear -->
                <Border CornerRadius="14"
                        Background="{StaticResource EveBackgroundDarkestBrush}"
                        BorderBrush="{StaticResource EveBorderBrush}"
                        BorderThickness="1" Padding="0"
                        MinWidth="240" MaxWidth="320">
                    <DockPanel>
                        <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                Content="&#x2715;" FontSize="10"
                                Background="Transparent" BorderThickness="0"
                                Padding="8,4" CornerRadius="0,14,14,0"
                                Click="OnClearFilter"
                                IsVisible="False" />
                        <TextBox x:Name="FilterBox"
                                 Watermark="Search skills..."
                                 FontSize="11" Padding="10,5"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 TextChanged="OnFilterChanged" />
                    </DockPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="10,5"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Text="Skills: 0" FontSize="11"
                       Foreground="{StaticResource EveTextSecondaryBrush}" />
        </Border>

        <!-- Dense DataGrid -->
        <DataGrid x:Name="SkillsGrid" Classes="plan-grid"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True" CanUserReorderColumns="True" CanUserSortColumns="True"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  Background="{StaticResource EveBackgroundDarkBrush}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource EveBorderBrush}"
                  SelectionMode="Extended">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy Skill Name" Click="OnCopySkillName" />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <!-- Skill Name -->
                <DataGridTemplateColumn Header="SKILL NAME" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="Bold"
                                       Foreground="{Binding NameColor}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Rank -->
                <DataGridTemplateColumn Header="RANK" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RankText}" FontSize="10"
                                       Foreground="{StaticResource EveTextDisabledBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Level: 5 colored blocks -->
                <DataGridTemplateColumn Header="LEVEL" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="2"
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Width="10" Height="12" CornerRadius="2"
                                        Background="{Binding Block1Color}"
                                        BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0.5" />
                                <Border Width="10" Height="12" CornerRadius="2"
                                        Background="{Binding Block2Color}"
                                        BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0.5" />
                                <Border Width="10" Height="12" CornerRadius="2"
                                        Background="{Binding Block3Color}"
                                        BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0.5" />
                                <Border Width="10" Height="12" CornerRadius="2"
                                        Background="{Binding Block4Color}"
                                        BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0.5" />
                                <Border Width="10" Height="12" CornerRadius="2"
                                        Background="{Binding Block5Color}"
                                        BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0.5" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- SP -->
                <DataGridTemplateColumn Header="SP" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SPText}" FontSize="10"
                                       Foreground="{StaticResource EveTextSecondaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"
                                       Margin="0,0,6,0" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Group -->
                <DataGridTemplateColumn Header="GROUP" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding GroupName}" FontSize="10"
                                       Foreground="{StaticResource EveTextDisabledBrush}"
                                       VerticalAlignment="Center" Margin="4,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
