<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:EVEMon.Avalonia.Views.Shared"
             x:Class="EVEMon.Avalonia.Views.CharacterMonitor.CharacterMedalsView">

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Medals is not enabled for this character."
                           FontSize="12"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enable this to start fetching data from EVE Online."
                           FontSize="11"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Enable Medals"
                        FontSize="11" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <Border x:Name="ScopePrompt" IsVisible="False" Padding="20">
            <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="ESI scope not authorized" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource EveTextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource EveTextDisabledBrush}" HorizontalAlignment="Center"
                           Text="This character was authenticated without the required scope.&#x0a;Re-authenticate from File → Manage Characters to enable this feature." />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Padding="10,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText" Text="Medals: 0" FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </Border>

            <!-- Grid for EmptyState + content overlap -->
            <Grid>
                <shared:EmptyState x:Name="EmptyState" IsVisible="False"
                                   Title="No medals"
                                   Subtitle="This character has not been awarded any medals" />
                <ScrollViewer x:Name="MedalScroller" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="MedalsList" Margin="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,4" Padding="12,8" CornerRadius="6"
                                        Background="{StaticResource EveBackgroundMediumBrush}"
                                        BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="1">
                                    <Grid RowDefinitions="Auto,Auto,Auto">
                                        <!-- Row 0: Title + Date -->
                                        <DockPanel Grid.Row="0">
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding IssuedText}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource EveTextSecondaryBrush}" />
                                            <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                        <!-- Row 1: Reason -->
                                        <TextBlock Grid.Row="1" Text="{Binding Reason}" FontSize="11"
                                                   Foreground="{StaticResource EveTextPrimaryBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"
                                                   IsVisible="{Binding HasReason}" />
                                        <!-- Row 2: Issuer + Corp -->
                                        <TextBlock Grid.Row="2" Text="{Binding IssuerCorpText}" FontSize="10"
                                                   Foreground="{StaticResource EveTextDisabledBrush}"
                                                   Margin="0,4,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </Panel>
</UserControl>
