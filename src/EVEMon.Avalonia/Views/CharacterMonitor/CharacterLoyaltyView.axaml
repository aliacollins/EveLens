<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:EVEMon.Avalonia.Views.Shared"
             x:Class="EVEMon.Avalonia.Views.CharacterMonitor.CharacterLoyaltyView">

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Loyalty Points is not enabled for this character."
                           FontSize="12"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enable this to start fetching data from EVE Online."
                           FontSize="11"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Enable Loyalty Points"
                        FontSize="11" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Padding="10,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText" Text="Corporations: 0" FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </Border>

            <!-- Grid for EmptyState + content overlap -->
            <Grid>
                <shared:EmptyState x:Name="EmptyState" IsVisible="False"
                                   Title="No loyalty points"
                                   Subtitle="Loyalty points from NPC corporations will appear here" />
                <ScrollViewer x:Name="LoyaltyScroller" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="LoyaltyList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,6" Background="{StaticResource EveBackgroundDarkBrush}"
                                        BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,0.5">
                                    <Grid ColumnDefinitions="Auto,*,Auto" MinHeight="36">
                                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                                Background="{StaticResource EveBackgroundMediumBrush}"
                                                Margin="0,0,10,0" VerticalAlignment="Center" ClipToBounds="True">
                                            <TextBlock Text="{Binding Initial}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource EveTextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding CorporationName}" FontSize="11"
                                                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2" Text="{Binding PointsText}" FontSize="11"
                                                   Foreground="{StaticResource EveSuccessGreenBrush}"
                                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </Panel>
</UserControl>
