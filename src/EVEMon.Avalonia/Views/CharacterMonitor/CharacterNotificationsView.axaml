<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.CharacterMonitor.CharacterNotificationsView">

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Notifications is not enabled for this character."
                           FontSize="12"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enable this to start fetching data from EVE Online."
                           FontSize="11"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Enable Notifications"
                        FontSize="11" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
        <!-- Filter bar -->
        <Border DockPanel.Dock="Top" Padding="8,4"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <DockPanel>
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="FilterBox"
                         Text="{Binding TextFilter, Mode=TwoWay}"
                         Watermark="Search notifications..."
                         MinWidth="200" />
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="8,4"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock>
                <TextBlock.Text>
                    <MultiBinding StringFormat="Items: {0}">
                        <Binding Path="TotalItemCount" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </Border>

        <!-- Data grid -->
        <DataGrid x:Name="ItemsGrid"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy Type" />
                    <MenuItem Header="Copy Sender" />
                    <Separator />
                    <MenuItem Header="Export to CSV..." />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Type" Binding="{Binding Title}" Width="250" />
                <DataGridTextColumn Header="Sender" Binding="{Binding SenderName}" Width="150" />
                <DataGridTextColumn Header="Date" Binding="{Binding SentDate, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>
        </DockPanel>
    </Panel>
</UserControl>
