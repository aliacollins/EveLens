<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:EVEMon.Avalonia.Views.Shared"
             x:Class="EVEMon.Avalonia.Views.CharacterMonitor.CharacterSkillQueueView">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Padding="10,5"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Text="Skills in queue: 0" FontSize="11"
                       Foreground="{StaticResource EveTextSecondaryBrush}" />
        </Border>
        <Grid>
            <!-- Empty state (shown when queue is empty) -->
            <shared:EmptyState x:Name="EmptyState" IsVisible="False"
                               Title="No skills in training"
                               Subtitle="Add skills to your queue in EVE Online to see them here" />
            <ScrollViewer x:Name="QueueScroller" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="QueueItems" Margin="0">
                <ItemsControl.Styles>
                    <Style Selector="ItemsControl > ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,6,12,6"
                                Background="{Binding RowBackground}"
                                BorderBrush="{StaticResource EveBorderBrush}"
                                BorderThickness="0,0,0,1"
                                HorizontalAlignment="Stretch">
                            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
                                <!-- Row 0: Skill name + rank + end time -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding SkillText}" FontSize="12"
                                               Foreground="{Binding NameBrush}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding RankText}" FontSize="10"
                                               Foreground="{StaticResource EveTextDisabledBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding StatusText}" FontSize="11"
                                           Foreground="{Binding StatusBrush}"
                                           VerticalAlignment="Center" Margin="8,0" />
                                <TextBlock Grid.Row="0" Grid.Column="2"
                                           Text="{Binding TimeText}" FontSize="10"
                                           Foreground="{StaticResource EveTextSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <!-- Row 1: Progress bar -->
                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="3"
                                             Value="{Binding Progress}" Minimum="0" Maximum="100"
                                             Height="4" Margin="0,4,0,0"
                                             Foreground="{Binding ProgressBrush}"
                                             Background="{StaticResource EveBackgroundDarkestBrush}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
