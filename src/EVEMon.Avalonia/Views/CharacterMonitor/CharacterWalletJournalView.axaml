<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:EVEMon.Avalonia.Views.Shared"
             xmlns:converters="clr-namespace:EVEMon.Avalonia.Converters"
             x:Class="EVEMon.Avalonia.Views.CharacterMonitor.CharacterWalletJournalView">

    <UserControl.Resources>
        <converters:AmountColorConverter x:Key="AmountColor" />
    </UserControl.Resources>

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Wallet Journal is not enabled for this character."
                           FontSize="12"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enable this to start fetching data from EVE Online."
                           FontSize="11"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Enable Wallet Journal"
                        FontSize="11" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Padding="10,7"
                    Background="{StaticResource EveBackgroundMediumBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <!-- Pill search bar -->
                    <Border CornerRadius="14"
                            Background="{StaticResource EveBackgroundDarkBrush}"
                            Padding="4,0" MinWidth="220">
                        <DockPanel>
                            <Button x:Name="ClearFilterButton"
                                    DockPanel.Dock="Right"
                                    Content="&#x2715;" FontSize="10"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,0" Cursor="Hand"
                                    IsVisible="False"
                                    Click="OnClearFilter" />
                            <TextBox x:Name="FilterBox"
                                     Watermark="Search journal..."
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="11" Padding="8,5"
                                     TextChanged="OnFilterTextChanged" />
                        </DockPanel>
                    </Border>

                    <!-- Type filter -->
                    <TextBlock Text="Type:" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource EveTextSecondaryBrush}" />
                    <ComboBox x:Name="TypeFilterCombo" FontSize="11"
                              MinWidth="140" Padding="8,4"
                              SelectionChanged="OnTypeFilterChanged" />

                    <!-- Grouping -->
                    <TextBlock Text="Group:" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource EveTextSecondaryBrush}" />
                    <ComboBox x:Name="GroupingCombo" FontSize="11"
                              MinWidth="140" Padding="8,4"
                              SelectionChanged="OnGroupingChanged" />
                </StackPanel>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Padding="10,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText" FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </Border>

            <Grid>
                <!-- Empty state -->
                <shared:EmptyState x:Name="EmptyState" IsVisible="False"
                                   Title="No journal entries"
                                   Subtitle="Wallet journal entries will appear here when available" />

                <!-- Data grid -->
                <DataGrid x:Name="ItemsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="{StaticResource EveBackgroundDarkBrush}"
                      Foreground="{StaticResource EveTextPrimaryBrush}"
                      FontSize="11">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy Entry" />
                        <MenuItem Header="Copy Amount" />
                        <Separator />
                        <MenuItem Header="Export to CSV..." />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=\{0:yyyy-MM-dd HH:mm\}}" Width="140" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="150" />
                    <DataGridTemplateColumn Header="Amount" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Amount, StringFormat=\{0:N2\} ISK}"
                                           Foreground="{Binding Amount, Converter={StaticResource AmountColor}}"
                                           VerticalAlignment="Center" Padding="4,0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Balance" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Balance, StringFormat=\{0:N2\} ISK}"
                                           Foreground="{StaticResource EveSuccessGreenBrush}"
                                           VerticalAlignment="Center" Padding="4,0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Issuer" Binding="{Binding Issuer}" Width="130" />
                    <DataGridTextColumn Header="Recipient" Binding="{Binding Recipient}" Width="130" />
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="200" />
                </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </DockPanel>
    </Panel>
</UserControl>
