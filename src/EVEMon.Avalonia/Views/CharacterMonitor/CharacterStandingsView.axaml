<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:EVEMon.Avalonia.Views.Shared"
             xmlns:converters="clr-namespace:EVEMon.Avalonia.Converters"
             x:Class="EVEMon.Avalonia.Views.CharacterMonitor.CharacterStandingsView">

    <UserControl.Resources>
        <converters:StandingColorConverter x:Key="StandingColorConverter" />
        <converters:StandingWidthConverter x:Key="StandingWidthConverter" />
    </UserControl.Resources>

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Standings is not enabled for this character."
                           FontSize="12"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enable this to start fetching data from EVE Online."
                           FontSize="11"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Enable Standings"
                        FontSize="11" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Padding="10,7"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- Right side: group selector + collapse/expand -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <TextBlock Text="Group by:" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{StaticResource EveTextSecondaryBrush}" />
                        <ComboBox x:Name="GroupByCombo" FontSize="11" Padding="8,3"
                                  MinWidth="120" SelectedIndex="0"
                                  SelectionChanged="OnGroupByChanged">
                            <ComboBoxItem Content="No group" />
                            <ComboBoxItem Content="Group" />
                            <ComboBoxItem Content="Status" />
                        </ComboBox>
                        <Button Content="Collapse All" FontSize="11" Padding="10,4"
                                CornerRadius="12" Click="OnCollapseAll" />
                        <Button Content="Expand All" FontSize="11" Padding="10,4"
                                CornerRadius="12" Click="OnExpandAll" />
                    </StackPanel>

                    <!-- Left side: search with clear -->
                    <Border CornerRadius="14"
                            Background="{StaticResource EveBackgroundDarkestBrush}"
                            BorderBrush="{StaticResource EveBorderBrush}"
                            BorderThickness="1" Padding="0"
                            MinWidth="240" MaxWidth="320">
                        <DockPanel>
                            <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                    Content="&#x2715;" FontSize="10"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="8,4" CornerRadius="0,14,14,0"
                                    Click="OnClearFilter"
                                    IsVisible="False" />
                            <TextBox x:Name="FilterBox"
                                     Watermark="Search standings..."
                                     FontSize="11" Padding="10,5"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextChanged="OnFilterChanged" />
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Padding="10,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText" Text="Standings: 0" FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </Border>

            <!-- Empty state + scrollable content overlap in Grid -->
            <Grid>
                <shared:EmptyState x:Name="EmptyState" IsVisible="False"
                                   Title="No standings found"
                                   Subtitle="This character has no standings, or none match the current filter" />

                <!-- Grouped standings list -->
                <ScrollViewer x:Name="MainScroller" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="StandingGroupsList" Margin="0"
                                  HorizontalAlignment="Stretch">
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl > ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="{Binding IsExpanded}"
                                          HorizontalAlignment="Stretch"
                                          Padding="0" Margin="0,0,0,1">

                                    <!-- Group header -->
                                    <Expander.Header>
                                        <Border Background="{StaticResource EveBackgroundMediumBrush}"
                                                Padding="10,6" HorizontalAlignment="Stretch">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  HorizontalAlignment="Stretch">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Name}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CountText}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource EveTextSecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0" />
                                            </Grid>
                                        </Border>
                                    </Expander.Header>

                                    <!-- Items in group -->
                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  HorizontalAlignment="Stretch">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="item-row" Padding="20,4,10,4"
                                                        Background="{StaticResource EveBackgroundDarkBrush}"
                                                        BorderBrush="{StaticResource EveBorderBrush}"
                                                        BorderThickness="0,0,0,0.5"
                                                        HorizontalAlignment="Stretch">
                                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto"
                                                          HorizontalAlignment="Stretch"
                                                          MinHeight="32">
                                                        <!-- Portrait -->
                                                        <Border Grid.Column="0" Width="32" Height="32"
                                                                CornerRadius="16"
                                                                Background="{StaticResource EveBackgroundMediumBrush}"
                                                                Margin="0,0,10,0"
                                                                VerticalAlignment="Center"
                                                                ClipToBounds="True">
                                                            <Panel>
                                                                <TextBlock Text="{Binding Initial}"
                                                                           FontSize="14" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource EveTextSecondaryBrush}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           IsVisible="{Binding !HasPortrait}" />
                                                                <Image Source="{Binding Portrait}" Width="32" Height="32"
                                                                       Stretch="UniformToFill"
                                                                       IsVisible="{Binding HasPortrait}" />
                                                            </Panel>
                                                        </Border>

                                                        <!-- Entity name -->
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding EntityName}"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />

                                                        <!-- Standing bar: 120px total, center origin -->
                                                        <Border Grid.Column="2" Width="120" Height="10"
                                                                CornerRadius="3"
                                                                Background="{StaticResource EveBackgroundDarkestBrush}"
                                                                VerticalAlignment="Center"
                                                                Margin="8,0">
                                                            <Panel>
                                                                <!-- Center line -->
                                                                <Border Width="1" Height="10"
                                                                        Background="{StaticResource EveTextDisabledBrush}"
                                                                        HorizontalAlignment="Center" />
                                                                <!-- Negative bar (left of center) -->
                                                                <Border Width="{Binding StandingNumeric, Converter={StaticResource StandingWidthConverter}}"
                                                                        Height="8" CornerRadius="2"
                                                                        Background="{StaticResource EveStandingNegativeBrush}"
                                                                        HorizontalAlignment="Center"
                                                                        Margin="-60,0,0,0"
                                                                        IsVisible="{Binding IsNegative}" />
                                                                <!-- Positive bar (right of center) -->
                                                                <Border Width="{Binding StandingNumeric, Converter={StaticResource StandingWidthConverter}}"
                                                                        Height="8" CornerRadius="2"
                                                                        Background="{StaticResource EveStandingPositiveBrush}"
                                                                        HorizontalAlignment="Center"
                                                                        Margin="60,0,0,0"
                                                                        IsVisible="{Binding IsPositive}" />
                                                            </Panel>
                                                        </Border>

                                                        <!-- Standing value -->
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding StandingText}"
                                                                   FontSize="11"
                                                                   Foreground="{Binding StandingBrush}"
                                                                   VerticalAlignment="Center"
                                                                   MinWidth="40"
                                                                   TextAlignment="Right"
                                                                   Margin="4,0" />

                                                        <!-- Effective standing -->
                                                        <TextBlock Grid.Column="4"
                                                                   Text="{Binding EffectiveText}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource EveTextSecondaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   MinWidth="50"
                                                                   TextAlignment="Right"
                                                                   Margin="4,0" />

                                                        <!-- Status label -->
                                                        <TextBlock Grid.Column="5"
                                                                   Text="{Binding StatusText}"
                                                                   FontSize="10"
                                                                   Foreground="{Binding StatusBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,0,0"
                                                                   MinWidth="60" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </Panel>
</UserControl>
