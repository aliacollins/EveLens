<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EVEMon.Avalonia.Views.CharacterMonitor.CharacterFactionalWarfareView">

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Factional Warfare is not enabled for this character."
                           FontSize="12"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enable this to start fetching data from EVE Online."
                           FontSize="11"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Enable Factional Warfare"
                        FontSize="11" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <Border x:Name="ScopePrompt" IsVisible="False" Padding="20">
            <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="ESI scope not authorized" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource EveTextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="11"
                           Foreground="{DynamicResource EveTextDisabledBrush}" HorizontalAlignment="Center"
                           Text="This character was authenticated without the required scope.&#x0a;Re-authenticate from File → Manage Characters to enable this feature." />
            </StackPanel>
        </Border>

        <Border x:Name="DataContent" Padding="20">
        <StackPanel DataContext="{Binding FactionalWarfareStats}" Spacing="8">
            <TextBlock Text="Factional Warfare Statistics" FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource EveAccentPrimaryBrush}" />
            <TextBlock Text="{Binding FactionName, StringFormat='Faction: {0}'}"
                       FontSize="12" Foreground="{DynamicResource EveTextSecondaryBrush}" />
            <TextBlock Text="{Binding EnlistedDate, StringFormat='Enlisted: {0:yyyy-MM-dd}'}"
                       FontSize="12" Foreground="{DynamicResource EveTextSecondaryBrush}" />
            <TextBlock Text="{Binding CurrentRank, StringFormat='Current Rank: {0}'}"
                       FontSize="12" Foreground="{DynamicResource EveTextSecondaryBrush}" />
            <TextBlock Text="{Binding HighestRank, StringFormat='Highest Rank: {0}'}"
                       FontSize="12" Foreground="{DynamicResource EveTextSecondaryBrush}" />
            <Separator Margin="0,4" />
            <TextBlock Text="Kills" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource EveTextPrimaryBrush}" />
            <TextBlock Text="{Binding KillsYesterday, StringFormat='Yesterday: {0}'}"
                       FontSize="11" Foreground="{DynamicResource EveTextSecondaryBrush}" />
            <TextBlock Text="{Binding KillsLastWeek, StringFormat='Last Week: {0}'}"
                       FontSize="11" Foreground="{DynamicResource EveTextSecondaryBrush}" />
            <TextBlock Text="{Binding KillsTotal, StringFormat='Total: {0}'}"
                       FontSize="11" Foreground="{DynamicResource EveTextSecondaryBrush}" />
            <Separator Margin="0,4" />
            <TextBlock Text="Victory Points" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource EveTextPrimaryBrush}" />
            <TextBlock Text="{Binding VictoryPointsYesterday, StringFormat='Yesterday: {0}'}"
                       FontSize="11" Foreground="{DynamicResource EveTextSecondaryBrush}" />
            <TextBlock Text="{Binding VictoryPointsLastWeek, StringFormat='Last Week: {0}'}"
                       FontSize="11" Foreground="{DynamicResource EveTextSecondaryBrush}" />
            <TextBlock Text="{Binding VictoryPointsTotal, StringFormat='Total: {0}'}"
                       FontSize="11" Foreground="{DynamicResource EveTextSecondaryBrush}" />
        </StackPanel>
        </Border>
    </Panel>
</UserControl>
