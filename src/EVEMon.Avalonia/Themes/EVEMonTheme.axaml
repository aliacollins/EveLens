<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         EVEMon Dark Theme — EVE Online Inspired
         ═══════════════════════════════════════════════════════════════ -->

    <Styles.Resources>
        <!-- Background palette -->
        <Color x:Key="EveBackgroundDarkest">#FF0D0D1A</Color>
        <Color x:Key="EveBackgroundDark">#FF1A1A2E</Color>
        <Color x:Key="EveBackgroundMedium">#FF16213E</Color>
        <Color x:Key="EveBackgroundLight">#FF0F3460</Color>

        <!-- Accent colors (EVE gold/amber) -->
        <Color x:Key="EveAccentPrimary">#FFE6A817</Color>
        <Color x:Key="EveAccentSecondary">#FFC9A227</Color>
        <Color x:Key="EveAccentDimmed">#FF8B7420</Color>

        <!-- Text colors (brighter for readability) -->
        <Color x:Key="EveTextPrimary">#FFF0F0F0</Color>
        <Color x:Key="EveTextSecondary">#FFAAAAAA</Color>
        <Color x:Key="EveTextDisabled">#FF707070</Color>

        <!-- Status colors -->
        <Color x:Key="EveErrorRed">#FFCF6679</Color>
        <Color x:Key="EveWarningYellow">#FFFFD54F</Color>
        <Color x:Key="EveSuccessGreen">#FF81C784</Color>

        <!-- Standing colors -->
        <Color x:Key="EveStandingNegative">#FFCF6679</Color>
        <Color x:Key="EveStandingPositive">#FF64B5F6</Color>
        <Color x:Key="EveStandingNeutral">#FF707070</Color>

        <!-- Hover / interactive -->
        <Color x:Key="EveHoverColor">#FF1E2A4A</Color>
        <SolidColorBrush x:Key="EveHoverBrush" Color="{StaticResource EveHoverColor}" />

        <!-- Selection / alternating rows -->
        <Color x:Key="EveSelectedColor">#FF1A3A6A</Color>
        <SolidColorBrush x:Key="EveSelectedBrush" Color="{StaticResource EveSelectedColor}" />
        <Color x:Key="EveAlternateRowColor">#FF151525</Color>
        <SolidColorBrush x:Key="EveAlternateRowBrush" Color="{StaticResource EveAlternateRowColor}" />

        <!-- Border / separator -->
        <Color x:Key="EveBorderColor">#FF2A2A4A</Color>
        <Color x:Key="EveBorderFocused">#FF0F3460</Color>

        <!-- Brushes for easy binding -->
        <SolidColorBrush x:Key="EveBackgroundDarkestBrush" Color="{StaticResource EveBackgroundDarkest}" />
        <SolidColorBrush x:Key="EveBackgroundDarkBrush" Color="{StaticResource EveBackgroundDark}" />
        <SolidColorBrush x:Key="EveBackgroundMediumBrush" Color="{StaticResource EveBackgroundMedium}" />
        <SolidColorBrush x:Key="EveBackgroundLightBrush" Color="{StaticResource EveBackgroundLight}" />
        <SolidColorBrush x:Key="EveAccentPrimaryBrush" Color="{StaticResource EveAccentPrimary}" />
        <SolidColorBrush x:Key="EveAccentSecondaryBrush" Color="{StaticResource EveAccentSecondary}" />
        <SolidColorBrush x:Key="EveAccentDimmedBrush" Color="{StaticResource EveAccentDimmed}" />
        <SolidColorBrush x:Key="EveTextPrimaryBrush" Color="{StaticResource EveTextPrimary}" />
        <SolidColorBrush x:Key="EveTextSecondaryBrush" Color="{StaticResource EveTextSecondary}" />
        <SolidColorBrush x:Key="EveTextDisabledBrush" Color="{StaticResource EveTextDisabled}" />
        <SolidColorBrush x:Key="EveErrorRedBrush" Color="{StaticResource EveErrorRed}" />
        <SolidColorBrush x:Key="EveWarningYellowBrush" Color="{StaticResource EveWarningYellow}" />
        <SolidColorBrush x:Key="EveSuccessGreenBrush" Color="{StaticResource EveSuccessGreen}" />
        <SolidColorBrush x:Key="EveStandingNegativeBrush" Color="{StaticResource EveStandingNegative}" />
        <SolidColorBrush x:Key="EveStandingPositiveBrush" Color="{StaticResource EveStandingPositive}" />
        <SolidColorBrush x:Key="EveStandingNeutralBrush" Color="{StaticResource EveStandingNeutral}" />
        <SolidColorBrush x:Key="EveBorderBrush" Color="{StaticResource EveBorderColor}" />
        <SolidColorBrush x:Key="EveBorderFocusedBrush" Color="{StaticResource EveBorderFocused}" />
    </Styles.Resources>

    <!-- ═══════════════════════════════════════════════════════════════
         Control Style Overrides
         ═══════════════════════════════════════════════════════════════ -->

    <!-- TextBlock -->
    <Style Selector="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
    </Style>

    <!-- Button -->
    <Style Selector="Button">
        <Setter Property="Background" Value="{StaticResource EveBackgroundLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EveBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="12,6" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource EveAccentDimmedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource EveAccentPrimaryBrush}" />
    </Style>
    <Style Selector="Button.accent">
        <Setter Property="Background" Value="{StaticResource EveAccentPrimaryBrush}" />
        <Setter Property="Foreground" Value="#FF1A1A2E" />
    </Style>

    <!-- TextBox -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{StaticResource EveBackgroundDarkestBrush}" />
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EveBorderBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource EveAccentPrimaryBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource EveAccentDimmedBrush}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderBrush" Value="{StaticResource EveAccentPrimaryBrush}" />
    </Style>

    <!-- TabControl -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="{StaticResource EveBackgroundDarkBrush}" />
    </Style>
    <Style Selector="TabItem">
        <Setter Property="Foreground" Value="{StaticResource EveTextSecondaryBrush}" />
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="{StaticResource EveAccentPrimaryBrush}" />
    </Style>
    <Style Selector="TabItem:pointerover">
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
    </Style>

    <!-- Expander: full-width header stretch fix -->
    <Style Selector="Expander">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Expander /template/ ToggleButton">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Expander /template/ ToggleButton /template/ ContentPresenter">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- DataGrid -->
    <Style Selector="DataGrid">
        <Setter Property="Background" Value="{StaticResource EveBackgroundDarkBrush}" />
        <Setter Property="RowBackground" Value="{StaticResource EveBackgroundDarkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EveBorderBrush}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource EveBorderBrush}" />
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource EveBorderBrush}" />
    </Style>
    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource EveBackgroundMediumBrush}" />
        <Setter Property="Foreground" Value="{StaticResource EveAccentSecondaryBrush}" />
    </Style>
    <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{StaticResource EveBackgroundLightBrush}" />
    </Style>
    <Style Selector="DataGridCell">
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
    </Style>

    <!-- ListBox -->
    <Style Selector="ListBox">
        <Setter Property="Background" Value="{StaticResource EveBackgroundDarkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EveBorderBrush}" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource EveBackgroundLightBrush}" />
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{StaticResource EveBackgroundMediumBrush}" />
    </Style>

    <!-- ComboBox -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{StaticResource EveBackgroundDarkestBrush}" />
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EveBorderBrush}" />
    </Style>

    <!-- ToggleButton -->
    <Style Selector="ToggleButton">
        <Setter Property="Background" Value="{StaticResource EveBackgroundLightBrush}" />
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EveBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
    <!-- CheckBox -->
    <Style Selector="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
    </Style>

    <!-- ToolTip -->
    <Style Selector="ToolTip">
        <Setter Property="Background" Value="{StaticResource EveBackgroundMediumBrush}" />
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EveBorderBrush}" />
    </Style>

    <!-- Window background -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource EveBackgroundDarkBrush}" />
    </Style>

    <!-- ScrollViewer -->
    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Modern thin scrollbar -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="8" />
        <Setter Property="MinWidth" Value="8" />
    </Style>
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="8" />
        <Setter Property="MinHeight" Value="8" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="{StaticResource EveAccentDimmedBrush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinWidth" Value="6" />
        <Setter Property="MinHeight" Value="6" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="{StaticResource EveAccentSecondaryBrush}" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pressed">
        <Setter Property="Background" Value="{StaticResource EveAccentPrimaryBrush}" />
    </Style>
    <Style Selector="ScrollBar /template/ RepeatButton">
        <Setter Property="IsVisible" Value="False" />
    </Style>

    <!-- Separator -->
    <Style Selector="Separator">
        <Setter Property="Background" Value="{StaticResource EveBorderBrush}" />
        <Setter Property="Margin" Value="4,2" />
    </Style>

    <!-- ContextMenu -->
    <Style Selector="ContextMenu">
        <Setter Property="Background" Value="{StaticResource EveBackgroundDarkBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EveBorderBrush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource EveTextPrimaryBrush}" />
        <Setter Property="Padding" Value="6,4" />
    </Style>
    <Style Selector="MenuItem:pointerover /template/ Border#PART_LayoutRoot">
        <Setter Property="Background" Value="{StaticResource EveBackgroundMediumBrush}" />
    </Style>

    <!-- Group header: lightweight collapsible section header (replaces heavy Expander chrome) -->
    <Style Selector="Border.group-header">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{StaticResource EveBackgroundMediumBrush}" />
        <Setter Property="Padding" Value="8,6" />
    </Style>
    <Style Selector="Border.group-header:pointerover">
        <Setter Property="Background" Value="{StaticResource EveBackgroundLightBrush}" />
    </Style>

    <!-- Item row: hover, selected, alternating -->
    <Style Selector="Border.item-row">
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Border.item-row:pointerover">
        <Setter Property="Background" Value="{StaticResource EveHoverBrush}" />
    </Style>
    <Style Selector="Border.item-row.selected">
        <Setter Property="Background" Value="{StaticResource EveSelectedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EveAccentPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="Padding" Value="17,3,8,3" />
    </Style>
    <Style Selector="Border.item-row.selected:pointerover">
        <Setter Property="Background" Value="{StaticResource EveSelectedBrush}" />
    </Style>
    <Style Selector="Border.item-row-alt">
        <Setter Property="Background" Value="{StaticResource EveAlternateRowBrush}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Border.item-row-alt:pointerover">
        <Setter Property="Background" Value="{StaticResource EveHoverBrush}" />
    </Style>
    <Style Selector="Border.item-row-alt.selected">
        <Setter Property="Background" Value="{StaticResource EveSelectedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource EveAccentPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="Padding" Value="17,3,8,3" />
    </Style>
    <Style Selector="Border.item-row-alt.selected:pointerover">
        <Setter Property="Background" Value="{StaticResource EveSelectedBrush}" />
    </Style>

    <!-- DataGrid alternating rows + row hover -->
    <Style Selector="DataGridRow:nth-child(even) /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{StaticResource EveAlternateRowBrush}" />
    </Style>
    <Style Selector="DataGridRow:pointerover /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{StaticResource EveHoverBrush}" />
    </Style>

    <!-- ToggleButton checked: gold foreground + bottom indicator for active tabs -->
    <Style Selector="ToggleButton:checked">
        <Setter Property="BorderBrush" Value="{StaticResource EveAccentPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,2" />
        <Setter Property="Padding" Value="10,4,10,2" />
    </Style>
    <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{StaticResource EveAccentDimmedBrush}" />
        <Setter Property="Foreground" Value="{StaticResource EveAccentPrimaryBrush}" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         Attribute Colors (EVE character attributes)
         ═══════════════════════════════════════════════════════════════ -->

    <Styles.Resources>
        <Color x:Key="EveAttrIntColor">#FF4FC3F7</Color>
        <Color x:Key="EveAttrPerColor">#FFEF5350</Color>
        <Color x:Key="EveAttrChaColor">#FF66BB6A</Color>
        <Color x:Key="EveAttrWilColor">#FFAB47BC</Color>
        <Color x:Key="EveAttrMemColor">#FFFFA726</Color>
        <SolidColorBrush x:Key="EveAttrIntBrush" Color="{StaticResource EveAttrIntColor}" />
        <SolidColorBrush x:Key="EveAttrPerBrush" Color="{StaticResource EveAttrPerColor}" />
        <SolidColorBrush x:Key="EveAttrChaBrush" Color="{StaticResource EveAttrChaColor}" />
        <SolidColorBrush x:Key="EveAttrWilBrush" Color="{StaticResource EveAttrWilColor}" />
        <SolidColorBrush x:Key="EveAttrMemBrush" Color="{StaticResource EveAttrMemColor}" />
    </Styles.Resources>

    <!-- ═══════════════════════════════════════════════════════════════
         Plan DataGrid Styles (.plan-grid class)
         ═══════════════════════════════════════════════════════════════ -->

    <Style Selector="DataGrid.plan-grid">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="RowHeight" Value="24" />
    </Style>
    <Style Selector="DataGrid.plan-grid DataGridRow">
        <Setter Property="MinHeight" Value="22" />
        <Setter Property="FontSize" Value="10" />
    </Style>
    <Style Selector="DataGrid.plan-grid DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
        <Setter Property="Fill" Value="{StaticResource EveBackgroundLightBrush}" />
    </Style>
    <Style Selector="DataGrid.plan-grid DataGridColumnHeader">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="Foreground" Value="{StaticResource EveTextDisabledBrush}" />
        <Setter Property="Padding" Value="4,3" />
        <Setter Property="MinHeight" Value="24" />
    </Style>

</Styles>
