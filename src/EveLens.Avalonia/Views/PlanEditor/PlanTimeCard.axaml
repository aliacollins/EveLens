<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EveLens.Avalonia.Views.PlanEditor.PlanTimeCard">
    <Border Background="{StaticResource EveBackgroundMediumBrush}"
            CornerRadius="6" Padding="12,10" Margin="4">
        <StackPanel Spacing="6">
            <TextBlock Text="Training Time" FontSize="{DynamicResource EveFontSmall}"
                       Foreground="{StaticResource EveTextDisabledBrush}" />
            <TextBlock x:Name="TotalTimeText" FontSize="{DynamicResource EveFontTitle}" FontWeight="Bold"
                       Foreground="{StaticResource EveTextPrimaryBrush}" />
            <TextBlock x:Name="CompletionText" FontSize="{DynamicResource EveFontBody}"
                       Foreground="{StaticResource EveTextSecondaryBrush}" />
        </StackPanel>
    </Border>
</UserControl>
