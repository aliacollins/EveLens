<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EveLens.Avalonia.Views.PlanEditor.PlanEditorWindow"
        Title="Plan Editor"
        Width="1100" Height="750"
        MinWidth="800" MinHeight="500"
        Icon="avares://EveLens/Properties/EveLens.ico"
        Background="{StaticResource EveBackgroundDarkBrush}">

    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Padding="10,7"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- Right: search -->
                <Border DockPanel.Dock="Right" CornerRadius="14"
                        Background="{StaticResource EveBackgroundDarkestBrush}"
                        BorderBrush="{StaticResource EveBorderBrush}"
                        BorderThickness="1" MinWidth="220" MaxWidth="300">
                    <DockPanel>
                        <Button x:Name="ClearSearchBtn" DockPanel.Dock="Right"
                                Content="&#x2715;" FontSize="10"
                                Background="Transparent" BorderThickness="0"
                                Padding="8,4" CornerRadius="0,14,14,0"
                                IsVisible="False" Click="OnClearSearch" />
                        <TextBox x:Name="SearchBox" Watermark="Search skills..."
                                 FontSize="11" Padding="10,5"
                                 Background="Transparent" BorderThickness="0"
                                 TextChanged="OnSearchChanged" />
                    </DockPanel>
                </Border>

                <!-- Left: plan name and character -->
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock x:Name="PlanNameText" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource EveAccentPrimaryBrush}" />
                    <TextBlock x:Name="CharacterNameText" FontSize="12"
                               Foreground="{StaticResource EveTextSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Tab strip -->
        <Border DockPanel.Dock="Top" Padding="10,4"
                Background="{StaticResource EveBackgroundMediumBrush}">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <ToggleButton x:Name="PlanTab" Content="Plan" IsChecked="True"
                              FontSize="11" Padding="12,5" CornerRadius="12"
                              Click="OnTabClicked" />
                <ToggleButton x:Name="SkillsTab" Content="Skills"
                              FontSize="11" Padding="12,5" CornerRadius="12"
                              Click="OnTabClicked" />
                <ToggleButton x:Name="ShipsTab" Content="Ships"
                              FontSize="11" Padding="12,5" CornerRadius="12"
                              Click="OnTabClicked" />
                <ToggleButton x:Name="ItemsTab" Content="Items"
                              FontSize="11" Padding="12,5" CornerRadius="12"
                              Click="OnTabClicked" />
                <ToggleButton x:Name="BlueprintsTab" Content="Blueprints"
                              FontSize="11" Padding="12,5" CornerRadius="12"
                              Click="OnTabClicked" />
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="10,5"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Export" FontSize="11"
                        Padding="10,4" CornerRadius="12" Click="OnExport" />
                <TextBlock x:Name="StatusText" FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Content area -->
        <Panel x:Name="ContentPanel">
            <!-- Views are swapped programmatically -->
        </Panel>
    </DockPanel>
</Window>
