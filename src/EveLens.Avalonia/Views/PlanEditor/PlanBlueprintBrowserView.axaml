<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EveLens.Avalonia.Views.PlanEditor.PlanBlueprintBrowserView">
    <Grid ColumnDefinitions="300,*">
        <!-- Left panel: Blueprint groups as lightweight tree -->
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top" Padding="8,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <Button Content="Collapse" FontSize="10" Padding="8,3" CornerRadius="10"
                                Click="OnCollapseAll" />
                        <Button Content="Expand" FontSize="10" Padding="8,3" CornerRadius="10"
                                Click="OnExpandAll" />
                    </StackPanel>
                    <Border CornerRadius="12" Background="{StaticResource EveBackgroundDarkestBrush}"
                            BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="1">
                        <DockPanel>
                            <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                    Content="&#x2715;" FontSize="9"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,3" CornerRadius="0,12,12,0"
                                    IsVisible="False" Click="OnClearFilter" />
                            <TextBox x:Name="FilterBox" Watermark="Search blueprints..."
                                     FontSize="10" Padding="8,4"
                                     Background="Transparent" BorderThickness="0"
                                     TextChanged="OnFilterChanged" />
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="GroupsList" HorizontalAlignment="Stretch">
                    <ItemsControl.Styles>
                        <Style Selector="ItemsControl > ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Border Classes="group-header" HorizontalAlignment="Stretch"
                                        PointerPressed="OnGroupHeaderClicked">
                                    <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
                                        <TextBlock Grid.Column="0" Text="{Binding Chevron}"
                                                   FontSize="11" Width="16"
                                                   Foreground="{StaticResource EveTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}"
                                                   FontSize="10" Foreground="{StaticResource EveTextSecondaryBrush}"
                                                   Margin="8,0" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- StackPanel (not VirtualizingStackPanel) to avoid nested virtualization
                                     breaking ScrollViewer measurement — Issue #39 -->
                                <ItemsControl ItemsSource="{Binding VisibleBlueprints}" HorizontalAlignment="Stretch"
                                              IsVisible="{Binding IsExpanded}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="24,3,8,3" Classes="item-row"
                                                    Background="{StaticResource EveBackgroundDarkBrush}"
                                                    BorderBrush="{StaticResource EveBorderBrush}"
                                                    BorderThickness="0,0,0,1" HorizontalAlignment="Stretch"
                                                    PointerPressed="OnBlueprintClicked">
                                                <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="11"
                                                               Foreground="{StaticResource EveTextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding ProducesText}"
                                                               FontSize="10" Foreground="{StaticResource EveTextDisabledBrush}"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- Right panel: Blueprint detail -->
        <Border Grid.Column="1" BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DetailPanel" Margin="16,12" Spacing="10" IsVisible="False">
                    <TextBlock x:Name="DetailName" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource EveAccentPrimaryBrush}" />
                    <TextBlock x:Name="DetailProduces" FontSize="11"
                               Foreground="{StaticResource EveTextSecondaryBrush}" />
                    <TextBlock x:Name="DetailTime" FontSize="11"
                               Foreground="{StaticResource EveTextSecondaryBrush}" />
                    <TextBlock x:Name="DetailDescription" FontSize="11" TextWrapping="Wrap"
                               Foreground="{StaticResource EveTextSecondaryBrush}"
                               MaxHeight="80" />
                    <Border Height="1" Background="{StaticResource EveBorderBrush}" Margin="0,4" />
                    <TextBlock Text="Required Skills:" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource EveTextPrimaryBrush}" />
                    <StackPanel x:Name="PrereqsList" Spacing="2" />
                    <Border Height="1" Background="{StaticResource EveBorderBrush}" Margin="0,4" />
                    <TextBlock Text="Materials:" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource EveTextPrimaryBrush}" />
                    <StackPanel x:Name="MaterialsList" Spacing="2" />
                    <Button x:Name="PlanSkillsBtn" Content="Plan Skills" FontSize="11"
                            Padding="12,5" CornerRadius="12" Margin="0,8,0,0"
                            Click="OnPlanSkills" IsVisible="False" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
