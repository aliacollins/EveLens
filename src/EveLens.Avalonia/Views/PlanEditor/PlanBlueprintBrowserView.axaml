<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EveLens.Avalonia.Views.PlanEditor.PlanBlueprintBrowserView">
    <Grid ColumnDefinitions="300,*">
        <!-- Left panel: Blueprint hierarchy as flat list with depth-based indentation -->
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top" Padding="8,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <ToggleButton x:Name="CanBuildToggle" Content="Can Build Only"
                                      FontSize="{DynamicResource EveFontSmall}" Padding="8,3" CornerRadius="10"
                                      Click="OnCanBuildToggled" />
                        <Button x:Name="CollapseBtn" Content="Collapse" FontSize="{DynamicResource EveFontSmall}" Padding="8,3" CornerRadius="10"
                                Click="OnCollapseAll" />
                        <Button x:Name="ExpandBtn" Content="Expand" FontSize="{DynamicResource EveFontSmall}" Padding="8,3" CornerRadius="10"
                                Click="OnExpandAll" />
                    </StackPanel>
                    <Border CornerRadius="12" Background="{StaticResource EveBackgroundDarkestBrush}"
                            BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="1">
                        <DockPanel>
                            <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                    Content="&#x2715;" FontSize="{DynamicResource EveFontCaption}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,3" CornerRadius="0,12,12,0"
                                    IsVisible="False" Click="OnClearFilter" />
                            <TextBox x:Name="FilterBox" Watermark="Search blueprints..."
                                     FontSize="{DynamicResource EveFontSmall}" Padding="8,4"
                                     Background="Transparent" BorderThickness="0"
                                     TextChanged="OnFilterChanged" />
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="TreeList" HorizontalAlignment="Stretch">
                    <ItemsControl.Styles>
                        <Style Selector="ItemsControl > ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Panel>
                                <!-- Category node: chevron + name + count, indented by depth -->
                                <Border IsVisible="{Binding IsCategory}" Classes="group-header"
                                        Margin="{Binding IndentMargin}"
                                        PointerPressed="OnNodeToggle">
                                    <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
                                        <TextBlock Grid.Column="0" Text="{Binding Chevron}"
                                                   FontSize="{DynamicResource EveFontBody}" Width="16"
                                                   Foreground="{StaticResource EveTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontSize="{DynamicResource EveFontBody}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding CountText}"
                                                   FontSize="{DynamicResource EveFontSmall}" Foreground="{StaticResource EveTextSecondaryBrush}"
                                                   Margin="8,0" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <!-- Leaf item: blueprint name + produces text -->
                                <Border IsVisible="{Binding IsLeaf}" Classes="item-row"
                                        Margin="{Binding IndentMargin}" Padding="4,3,8,3"
                                        Background="{StaticResource EveBackgroundDarkBrush}"
                                        BorderBrush="{StaticResource EveBorderBrush}"
                                        BorderThickness="0,0,0,1" HorizontalAlignment="Stretch"
                                        PointerPressed="OnBlueprintClicked">
                                    <Grid ColumnDefinitions="*,Auto" HorizontalAlignment="Stretch">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="{DynamicResource EveFontBody}"
                                                   Foreground="{Binding NameBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                                                   FontSize="{DynamicResource EveFontSmall}" Foreground="{Binding StatusBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Panel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- Right panel: Blueprint detail -->
        <Border Grid.Column="1" BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DetailPanel" Margin="16,12" Spacing="10" IsVisible="False">
                    <TextBlock x:Name="DetailName" FontSize="{DynamicResource EveFontTitle}" FontWeight="Bold"
                               Foreground="{StaticResource EveAccentPrimaryBrush}" />
                    <TextBlock x:Name="DetailProduces" FontSize="{DynamicResource EveFontBody}"
                               Foreground="{StaticResource EveTextSecondaryBrush}" />
                    <TextBlock x:Name="DetailTime" FontSize="{DynamicResource EveFontBody}"
                               Foreground="{StaticResource EveTextSecondaryBrush}" />
                    <TextBlock x:Name="DetailDescription" FontSize="{DynamicResource EveFontBody}" TextWrapping="Wrap"
                               Foreground="{StaticResource EveTextSecondaryBrush}"
                               MaxHeight="80" />
                    <Border Height="1" Background="{StaticResource EveBorderBrush}" Margin="0,4" />
                    <TextBlock x:Name="RequiredSkillsLabel" Text="Required Skills:" FontSize="{DynamicResource EveFontSubheading}" FontWeight="SemiBold"
                               Foreground="{StaticResource EveTextPrimaryBrush}" />
                    <StackPanel x:Name="PrereqsList" Spacing="2" />
                    <Border Height="1" Background="{StaticResource EveBorderBrush}" Margin="0,4" />
                    <TextBlock x:Name="MaterialsLabel" Text="Materials:" FontSize="{DynamicResource EveFontSubheading}" FontWeight="SemiBold"
                               Foreground="{StaticResource EveTextPrimaryBrush}" />
                    <StackPanel x:Name="MaterialsList" Spacing="2" />
                    <Button x:Name="PlanSkillsBtn" Content="Plan Skills" FontSize="{DynamicResource EveFontBody}"
                            Padding="12,5" CornerRadius="12" Margin="0,8,0,0"
                            Click="OnPlanSkills" IsVisible="False" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
