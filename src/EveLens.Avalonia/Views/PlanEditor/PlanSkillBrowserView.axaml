<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EveLens.Avalonia.Views.PlanEditor.PlanSkillBrowserView">
    <Grid ColumnDefinitions="300,*">
        <!-- Left panel: Skill groups as lightweight tree -->
        <DockPanel Grid.Column="0">
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Padding="8,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <WrapPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,4,0,0">
                        <ToggleButton x:Name="FilterAllBtn" Content="All Skills" IsChecked="True"
                                      FontSize="{DynamicResource EveFontSmall}" Padding="8,3" Margin="0,0,4,4" CornerRadius="10"
                                      Click="OnFilterModeClick" />
                        <ToggleButton x:Name="FilterTrainedBtn" Content="Trained"
                                      FontSize="{DynamicResource EveFontSmall}" Padding="8,3" Margin="0,0,4,4" CornerRadius="10"
                                      Click="OnFilterModeClick" />
                        <ToggleButton x:Name="FilterPrereqBtn" Content="Have Prerequisites"
                                      FontSize="{DynamicResource EveFontSmall}" Padding="8,3" Margin="0,0,4,4" CornerRadius="10"
                                      Click="OnFilterModeClick" />
                        <ToggleButton x:Name="FilterUntrainedBtn" Content="Untrained"
                                      FontSize="{DynamicResource EveFontSmall}" Padding="8,3" Margin="0,0,4,4" CornerRadius="10"
                                      Click="OnFilterModeClick" />
                        <Button Content="Collapse" FontSize="{DynamicResource EveFontSmall}" Padding="8,3" Margin="0,0,4,4" CornerRadius="10"
                                Click="OnCollapseAll" />
                        <Button Content="Expand" FontSize="{DynamicResource EveFontSmall}" Padding="8,3" Margin="0,0,4,4" CornerRadius="10"
                                Click="OnExpandAll" />
                    </WrapPanel>
                    <!-- Attribute filter -->
                    <ComboBox x:Name="AttributeComboBox" DockPanel.Dock="Bottom"
                              FontSize="{DynamicResource EveFontSmall}" Padding="6,3" Margin="0,4,0,0"
                              CornerRadius="10" HorizontalAlignment="Stretch"
                              SelectionChanged="OnAttributeFilterChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Text}" FontSize="{DynamicResource EveFontSmall}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding StarText}" FontSize="{DynamicResource EveFontSmall}"
                                               Foreground="{StaticResource EveAccentPrimaryBrush}"
                                               Margin="6,0,0,0" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <!-- Search -->
                    <Border CornerRadius="12" Background="{StaticResource EveBackgroundDarkestBrush}"
                            BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="1">
                        <DockPanel>
                            <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                    Content="&#x2715;" FontSize="{DynamicResource EveFontCaption}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,3" CornerRadius="0,12,12,0"
                                    IsVisible="False" Click="OnClearFilter" />
                            <TextBox x:Name="FilterBox" Watermark="Search skills..."
                                     FontSize="{DynamicResource EveFontSmall}" Padding="8,4"
                                     Background="Transparent" BorderThickness="0"
                                     TextChanged="OnFilterChanged" />
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Skill groups list: flat tree with collapsible sections -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="GroupsList" HorizontalAlignment="Stretch">
                    <ItemsControl.Styles>
                        <Style Selector="ItemsControl > ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.Styles>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Section header -->
                                <Border Classes="group-header" HorizontalAlignment="Stretch"
                                        PointerPressed="OnGroupHeaderClicked">
                                    <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
                                        <TextBlock Grid.Column="0" Text="{Binding Chevron}"
                                                   FontSize="{DynamicResource EveFontBody}" Width="16"
                                                   Foreground="{StaticResource EveTextSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontSize="{DynamicResource EveFontBody}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding TrainedCountText}"
                                                   FontSize="{DynamicResource EveFontSmall}" Foreground="{StaticResource EveTextSecondaryBrush}"
                                                   Margin="8,0" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Indented child items (uses StackPanel, not VirtualizingStackPanel,
                                     to avoid nested virtualization breaking ScrollViewer measurement — Issue #39) -->
                                <ItemsControl ItemsSource="{Binding VisibleSkills}" HorizontalAlignment="Stretch"
                                              IsVisible="{Binding IsExpanded}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="24,3,8,3" Classes="item-row"
                                                    Background="{StaticResource EveBackgroundDarkBrush}"
                                                    BorderBrush="{StaticResource EveBorderBrush}"
                                                    BorderThickness="0,0,0,1" HorizontalAlignment="Stretch"
                                                    PointerPressed="OnSkillItemClicked">
                                                <Grid ColumnDefinitions="*,Auto,Auto" HorizontalAlignment="Stretch">
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="{DynamicResource EveFontBody}"
                                                               Foreground="{Binding NameBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding LevelText}"
                                                               FontSize="{DynamicResource EveFontSmall}" Foreground="{StaticResource EveTextSecondaryBrush}"
                                                               Margin="8,0" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding RankText}"
                                                               FontSize="{DynamicResource EveFontSmall}" Foreground="{StaticResource EveTextDisabledBrush}"
                                                               MinWidth="60" TextAlignment="Right"
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- Right panel: Skill detail -->
        <Border Grid.Column="1" BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DetailPanel" Margin="16,12" Spacing="10" IsVisible="False">
                    <TextBlock x:Name="DetailName" FontSize="{DynamicResource EveFontTitle}" FontWeight="Bold"
                               Foreground="{StaticResource EveAccentPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Rank:" FontSize="{DynamicResource EveFontBody}"
                                       Foreground="{StaticResource EveTextSecondaryBrush}" />
                            <TextBlock x:Name="DetailRank" FontSize="{DynamicResource EveFontBody}"
                                       Foreground="{StaticResource EveTextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Primary:" FontSize="{DynamicResource EveFontBody}"
                                       Foreground="{StaticResource EveTextSecondaryBrush}" />
                            <TextBlock x:Name="DetailPrimary" FontSize="{DynamicResource EveFontBody}"
                                       Foreground="{StaticResource EveTextPrimaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Secondary:" FontSize="{DynamicResource EveFontBody}"
                                       Foreground="{StaticResource EveTextSecondaryBrush}" />
                            <TextBlock x:Name="DetailSecondary" FontSize="{DynamicResource EveFontBody}"
                                       Foreground="{StaticResource EveTextPrimaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="DetailDescription" FontSize="{DynamicResource EveFontBody}" TextWrapping="Wrap"
                               Foreground="{StaticResource EveTextSecondaryBrush}"
                               MaxHeight="80" />
                    <Border Height="1" Background="{StaticResource EveBorderBrush}" Margin="0,4" />
                    <TextBlock Text="Training Time:" FontSize="{DynamicResource EveFontSubheading}" FontWeight="SemiBold"
                               Foreground="{StaticResource EveTextPrimaryBrush}" />
                    <StackPanel x:Name="LevelsList" Spacing="4" />
                    <Border Height="1" Background="{StaticResource EveBorderBrush}" Margin="0,4" />
                    <TextBlock Text="Prerequisites:" FontSize="{DynamicResource EveFontSubheading}" FontWeight="SemiBold"
                               Foreground="{StaticResource EveTextPrimaryBrush}" />
                    <StackPanel x:Name="PrereqsList" Spacing="2" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
