<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EveLens.Avalonia.Views.Dialogs.CreateBlankCharacterWindow"
        Title="Create Blank Character"
        Width="460" Height="520"
        WindowStartupLocation="CenterOwner"
        Icon="avares://EveLens/Properties/EveLens.ico"
        CanResize="True">

    <DockPanel Margin="20">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Create a local character for planning"
                   FontSize="{DynamicResource EveFontBody}"
                   Foreground="{StaticResource EveTextSecondaryBrush}"
                   Margin="0,0,0,12" />

        <!-- Name -->
        <TextBlock DockPanel.Dock="Top" Text="Name" FontSize="{DynamicResource EveFontBody}"
                   Foreground="{StaticResource EveTextPrimaryBrush}"
                   Margin="0,0,0,4" />
        <TextBox x:Name="CharacterNameTextBox" DockPanel.Dock="Top"
                 Watermark="Enter character name..."
                 FontSize="{DynamicResource EveFontBody}"
                 Margin="0,0,0,12" />

        <!-- Race -->
        <TextBlock DockPanel.Dock="Top" Text="Race" FontSize="{DynamicResource EveFontBody}"
                   Foreground="{StaticResource EveTextPrimaryBrush}"
                   Margin="0,0,0,4" />
        <ComboBox x:Name="RaceCombo" DockPanel.Dock="Top"
                  FontSize="{DynamicResource EveFontBody}" HorizontalAlignment="Stretch"
                  Margin="0,0,0,12" />

        <!-- Skill summary header -->
        <TextBlock x:Name="SkillSummaryHeader" DockPanel.Dock="Top"
                   Text="Starting Skills"
                   FontSize="{DynamicResource EveFontSubheading}" FontWeight="SemiBold"
                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                   Margin="0,0,0,6" />

        <!-- Bottom row: SP text + buttons -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <TextBlock x:Name="SkillPointsText" DockPanel.Dock="Left"
                       Text="" FontSize="{DynamicResource EveFontBody}"
                       Foreground="{StaticResource EveTextSecondaryBrush}"
                       VerticalAlignment="Center" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="CreateBtn" Content="Create"
                        FontSize="{DynamicResource EveFontBody}" Padding="14,6"
                        CornerRadius="12"
                        Foreground="{StaticResource EveAccentPrimaryBrush}" />
                <Button x:Name="CancelBtn" Content="Cancel"
                        FontSize="{DynamicResource EveFontBody}" Padding="14,6"
                        CornerRadius="12" />
            </StackPanel>
        </DockPanel>

        <!-- Skill list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="SkillListPanel" />
        </ScrollViewer>
    </DockPanel>
</Window>
