<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EveLens.Avalonia.Views.Dialogs.AboutWindow"
        Title="About EveLens"
        Width="720" Height="680"
        WindowStartupLocation="CenterOwner"
        Icon="avares://EveLens/Properties/EveLens.ico"
        CanResize="False">

    <DockPanel>

        <!-- Header section -->
        <Border DockPanel.Dock="Top" Padding="24,20,24,0">
            <DockPanel>
                <!-- App icon -->
                <Border DockPanel.Dock="Left" Width="56" Height="56" CornerRadius="14"
                        Margin="0,0,20,0" VerticalAlignment="Top"
                        ClipToBounds="True">
                    <Image Source="avares://EveLens/Properties/EveLens.ico"
                           Width="56" Height="56"
                           Stretch="UniformToFill" />
                </Border>

                <!-- Title and info -->
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="EveLens" FontSize="{DynamicResource EveFontTitle}" FontWeight="SemiBold"
                               Foreground="{StaticResource EveTextPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <TextBlock x:Name="VersionText" FontSize="{DynamicResource EveFontBody}"
                                   Foreground="{StaticResource EveTextDisabledBrush}" />
                        <TextBlock Text="." FontSize="{DynamicResource EveFontSmall}"
                                   Foreground="{StaticResource EveTextDisabledBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=".NET 8 . Avalonia" FontSize="{DynamicResource EveFontBody}"
                                   Foreground="{StaticResource EveTextSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock Text="Character intelligence for EVE Online. Built on 20 years of community work."
                               FontSize="{DynamicResource EveFontBody}" Foreground="{StaticResource EveTextSecondaryBrush}"
                               Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Tab bar -->
        <Border DockPanel.Dock="Top" Padding="24,12,24,0"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel x:Name="TabBar" Orientation="Horizontal" Spacing="4" />
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Padding="24,8"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0"
                Background="{StaticResource EveBackgroundMediumBrush}">
            <DockPanel>
                <TextBlock Text="EVE Online and all related logos are trademarks of CCP hf."
                           FontSize="{DynamicResource EveFontSmall}" Foreground="{StaticResource EveTextDisabledBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="Fly safe. o7" FontSize="{DynamicResource EveFontSmall}"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Right" DockPanel.Dock="Right"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Close button -->
        <Border DockPanel.Dock="Bottom" Padding="24,10">
            <Button x:Name="OkButton" Content="Close"
                    FontSize="{DynamicResource EveFontBody}" Padding="20,6" CornerRadius="12"
                    HorizontalAlignment="Right" />
        </Border>

        <!-- Tab content area (no scroll — window is large enough) -->
        <Border Padding="24,16,24,8">
            <Panel x:Name="TabContent" />
        </Border>

    </DockPanel>
</Window>
