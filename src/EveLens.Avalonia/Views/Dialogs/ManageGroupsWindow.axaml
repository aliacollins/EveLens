<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EveLens.Avalonia.Views.Dialogs.ManageGroupsWindow"
        Title="Manage Character Groups"
        Width="650" Height="500"
        WindowStartupLocation="CenterOwner"
        Icon="avares://EveLens/Properties/EveLens.ico"
        Background="{StaticResource EveBackgroundDarkBrush}">

    <DockPanel Margin="12">
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="6" Margin="0,8,0,0">
            <Button x:Name="CloseBtn" Content="Close" FontSize="11"
                    Padding="10,4" CornerRadius="12" Click="OnCloseClick" />
        </StackPanel>

        <!-- Main content: two columns -->
        <Grid ColumnDefinitions="240,*">
            <!-- Left: Groups list -->
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock DockPanel.Dock="Top" Text="Groups" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource EveAccentPrimaryBrush}"
                           Margin="0,0,0,6" />

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6"
                            Margin="0,6,0,0">
                    <Button x:Name="AddGroupBtn" Content="Add Group" FontSize="10"
                            Padding="8,3" CornerRadius="12" Click="OnAddGroupClick" />
                    <Button x:Name="RenameGroupBtn" Content="Rename" FontSize="10"
                            Padding="8,3" CornerRadius="12" Click="OnRenameGroupClick" />
                    <Button x:Name="DeleteGroupBtn" Content="Delete" FontSize="10"
                            Padding="8,3" CornerRadius="12"
                            Foreground="{StaticResource EveErrorRedBrush}"
                            Click="OnDeleteGroupClick" />
                </StackPanel>

                <ListBox x:Name="GroupListBox"
                         Background="{StaticResource EveBackgroundMediumBrush}"
                         SelectionChanged="OnGroupSelected" />
            </DockPanel>

            <!-- Right: Character assignment -->
            <DockPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock x:Name="CharacterHeader" DockPanel.Dock="Top"
                           Text="Select a group" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource EveAccentPrimaryBrush}"
                           Margin="0,0,0,6" />

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="CharacterPanel" Spacing="4" />
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
