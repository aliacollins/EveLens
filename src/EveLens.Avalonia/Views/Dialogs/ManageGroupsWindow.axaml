<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EveLens.Avalonia.Views.Dialogs.ManageGroupsWindow"
        Title="Manage Character Groups"
        Width="550" Height="500"
        WindowStartupLocation="CenterOwner"
        Icon="avares://EveLens/Properties/EveLens.ico"
        Background="{StaticResource EveBackgroundDarkBrush}">

    <DockPanel Margin="12">
        <!-- Bottom: Done button -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="6" Margin="0,8,0,0">
            <Button x:Name="CloseBtn" Content="Done" FontSize="{DynamicResource EveFontBody}"
                    Padding="14,5" CornerRadius="12" Click="OnCloseClick" />
        </StackPanel>

        <!-- Bottom: Group management bar -->
        <Border DockPanel.Dock="Bottom" Padding="8,8"
                Background="{StaticResource EveBackgroundMediumBrush}"
                CornerRadius="6" Margin="0,8,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Groups" FontSize="{DynamicResource EveFontBody}" FontWeight="SemiBold"
                           Foreground="{StaticResource EveAccentPrimaryBrush}"
                           Margin="0,0,0,6" />
                <WrapPanel x:Name="GroupChipsPanel" DockPanel.Dock="Top"
                           Orientation="Horizontal" Margin="0,0,0,6" />
                <Button x:Name="NewGroupBtn" Content="+ New Group" FontSize="{DynamicResource EveFontSmall}"
                        Padding="8,3" CornerRadius="12" Click="OnNewGroupClick" />
            </DockPanel>
        </Border>

        <!-- Main: Character list with tags -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="CharacterListPanel" Spacing="2" />
        </ScrollViewer>
    </DockPanel>
</Window>
