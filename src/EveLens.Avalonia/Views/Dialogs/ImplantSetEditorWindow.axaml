<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EveLens.Avalonia.Views.Dialogs.ImplantSetEditorWindow"
        Title="Implant Set Editor"
        Width="700" Height="550"
        WindowStartupLocation="CenterOwner"
        Icon="avares://EveLens/Properties/EveLens.ico"
        Background="{StaticResource EveBackgroundDarkBrush}">

    <Grid ColumnDefinitions="200,*" Margin="12">
        <!-- Left: Implant set list -->
        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock DockPanel.Dock="Top" Text="Implant Sets" FontSize="{DynamicResource EveFontSubheading}" FontWeight="SemiBold"
                       Foreground="{StaticResource EveAccentPrimaryBrush}"
                       Margin="0,0,0,6" />

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="6"
                        Margin="0,6,0,0">
                <Button x:Name="NewCustomBtn" Content="New Custom" FontSize="{DynamicResource EveFontSmall}"
                        Padding="8,3" CornerRadius="12" Click="OnNewCustomClick" />
                <Button x:Name="RenameSetBtn" Content="Rename" FontSize="{DynamicResource EveFontSmall}"
                        Padding="8,3" CornerRadius="12" Click="OnRenameClick" />
                <Button x:Name="DeleteSetBtn" Content="Delete" FontSize="{DynamicResource EveFontSmall}"
                        Padding="8,3" CornerRadius="12"
                        Foreground="{StaticResource EveErrorRedBrush}"
                        Click="OnDeleteClick" />
            </StackPanel>

            <ListBox x:Name="SetListBox"
                     Background="{StaticResource EveBackgroundMediumBrush}"
                     SelectionChanged="OnSetSelected" />
        </DockPanel>

        <!-- Right: Implant slots + summary -->
        <DockPanel Grid.Column="1" Margin="8,0,0,0">
            <TextBlock DockPanel.Dock="Top" x:Name="SlotHeader" Text="Select an implant set"
                       FontSize="{DynamicResource EveFontSubheading}" FontWeight="SemiBold"
                       Foreground="{StaticResource EveAccentPrimaryBrush}"
                       Margin="0,0,0,6" />

            <!-- Bottom: Bonus summary -->
            <Border DockPanel.Dock="Bottom" Padding="8,6"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    CornerRadius="6" Margin="0,8,0,0">
                <TextBlock x:Name="BonusSummaryText" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </Border>

            <!-- Slot ComboBoxes -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="SlotPanel" Spacing="6" />
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
