<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EveLens.Avalonia.Views.Dialogs.ManagePlansWindow"
        Title="Manage Plans"
        Width="600" Height="450"
        WindowStartupLocation="CenterOwner"
        Icon="avares://EveLens/Properties/EveLens.ico"
        Background="{StaticResource EveBackgroundDarkBrush}">

    <DockPanel Margin="12">
        <!-- Bottom button bar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    Spacing="6" Margin="0,8,0,0">
            <Button x:Name="OpenBtn" Content="Open" FontSize="{DynamicResource EveFontBody}"
                    Padding="10,4" CornerRadius="12" Click="OnOpenClick" />
            <Button x:Name="NewBtn" Content="New" FontSize="{DynamicResource EveFontBody}"
                    Padding="10,4" CornerRadius="12" Click="OnNewClick" />
            <Button x:Name="DuplicateBtn" Content="Duplicate" FontSize="{DynamicResource EveFontBody}"
                    Padding="10,4" CornerRadius="12" Click="OnDuplicateClick" />
            <Button x:Name="RenameBtn" Content="Rename" FontSize="{DynamicResource EveFontBody}"
                    Padding="10,4" CornerRadius="12" Click="OnRenameClick" />
            <Button x:Name="DeleteBtn" Content="Delete" FontSize="{DynamicResource EveFontBody}"
                    Padding="10,4" CornerRadius="12"
                    Foreground="{StaticResource EveErrorRedBrush}"
                    Click="OnDeleteClick" />
            <Separator Width="1" Margin="4,0" />
            <Button x:Name="ImportBtn" Content="Import..." FontSize="{DynamicResource EveFontBody}"
                    Padding="10,4" CornerRadius="12" Click="OnImportClick" />
            <Button x:Name="FromQueueBtn" Content="From Queue" FontSize="{DynamicResource EveFontBody}"
                    Padding="10,4" CornerRadius="12" Click="OnFromQueueClick" />
        </StackPanel>

        <!-- Plan DataGrid -->
        <DataGrid x:Name="PlanGrid" AutoGenerateColumns="False"
                  CanUserReorderColumns="False" CanUserResizeColumns="True"
                  IsReadOnly="True" SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  Background="{StaticResource EveBackgroundMediumBrush}"
                  Foreground="{StaticResource EveTextPrimaryBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Skills" Binding="{Binding SkillCount}" Width="70" />
                <DataGridTextColumn Header="Training Time" Binding="{Binding TrainingTime}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
