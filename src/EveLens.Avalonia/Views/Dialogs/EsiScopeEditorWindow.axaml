<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EveLens.Avalonia.Views.Dialogs.EsiScopeEditorWindow"
        Title="ESI Scope Editor"
        Width="520" Height="580"
        WindowStartupLocation="CenterOwner"
        Icon="avares://EveLens/Properties/EveLens.ico"
        CanResize="False">

    <DockPanel Margin="12">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Select ESI Scopes"
                   FontSize="{DynamicResource EveFontTitle}" FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <TextBlock DockPanel.Dock="Top"
                   Text="Check the feature groups and individual scopes to request. Skills &amp; Training Queue is always required."
                   TextWrapping="Wrap" FontSize="{DynamicResource EveFontSubheading}" Foreground="Gray"
                   Margin="0,0,0,8" />

        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button x:Name="SelectAllButton" Content="Select All"
                    Padding="10,4" CornerRadius="12" />
            <Button x:Name="ClearAllButton" Content="Clear All"
                    Padding="10,4" CornerRadius="12" />
            <Button x:Name="OkButton" Content="OK"
                    Padding="10,4" CornerRadius="12" FontWeight="SemiBold" />
            <Button x:Name="CancelButton" Content="Cancel"
                    Padding="10,4" CornerRadius="12" />
        </StackPanel>

        <!-- Scope tree -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4"
                Margin="0,4" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ScopePanel" Spacing="4" />
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
