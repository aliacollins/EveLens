<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EveLens.Avalonia.Views.Dialogs.AddCharacterWindow"
        Title="Add Character"
        Width="420" Height="320"
        WindowStartupLocation="CenterOwner"
        Icon="avares://EveLens/Properties/EveLens.ico"
        CanResize="False">

    <Grid Margin="20">
        <!-- State: Ready (initial landing) -->
        <Border x:Name="ReadyPanel" IsVisible="True">
            <StackPanel VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Sign in with EVE Online"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource EveAccentPrimaryBrush}" />
                <TextBlock Text="Your browser will open to CCP's secure login page. EveLens never sees your password."
                           FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0"
                            HorizontalAlignment="Right">
                    <Button x:Name="OpenLoginBtn"
                            Content="Sign in with EVE"
                            FontSize="11" Padding="14,6"
                            CornerRadius="12"
                            Foreground="{StaticResource EveAccentPrimaryBrush}" />
                    <Button x:Name="CancelReadyBtn"
                            Content="Cancel"
                            FontSize="11" Padding="14,6"
                            CornerRadius="12" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- State: Waiting for browser login -->
        <Border x:Name="WaitingPanel" IsVisible="False">
            <StackPanel VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Waiting for login..."
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource EveWarningYellowBrush}" />
                <TextBlock Text="Complete the sign-in in your browser, then return here."
                           FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <ProgressBar IsIndeterminate="True" Margin="0,8,0,0"
                             Height="3"
                             Foreground="{StaticResource EveAccentPrimaryBrush}" />
                <Button x:Name="CancelWaitingBtn"
                        Content="Cancel"
                        FontSize="11" Padding="14,6"
                        CornerRadius="12"
                        HorizontalAlignment="Right"
                        Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- State: Success (character auto-imported) -->
        <Border x:Name="SuccessPanel" IsVisible="False">
            <StackPanel VerticalAlignment="Top" Spacing="8">
                <!-- Just-added character -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="&#x2713;" FontSize="18"
                               Foreground="{StaticResource EveSuccessGreenBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="CharacterNameText"
                                   Text="Character Name"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource EveAccentPrimaryBrush}" />
                        <TextBlock Text="Added successfully"
                                   FontSize="11"
                                   Foreground="{StaticResource EveSuccessGreenBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Previously added this session -->
                <Border x:Name="PreviousAddsDivider"
                        Height="1" Background="{StaticResource EveBorderBrush}"
                        Margin="0,4" IsVisible="False" />
                <TextBlock x:Name="PreviousAddsLabel"
                           Text="Added earlier this session:"
                           FontSize="10"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           IsVisible="False" />
                <StackPanel x:Name="PreviousAddsList" Spacing="2" />

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0"
                            HorizontalAlignment="Right">
                    <Button x:Name="AddAnotherBtn"
                            Content="+ Add Another"
                            FontSize="11" Padding="14,6"
                            CornerRadius="12"
                            Foreground="{StaticResource EveAccentPrimaryBrush}" />
                    <Button x:Name="DoneBtn"
                            Content="Done"
                            FontSize="11" Padding="14,6"
                            CornerRadius="12" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- State: Error -->
        <Border x:Name="ErrorPanel" IsVisible="False">
            <StackPanel VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Authentication failed"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource EveErrorRedBrush}" />
                <TextBlock x:Name="ErrorMessageText"
                           Text="An error occurred."
                           FontSize="11"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0"
                            HorizontalAlignment="Right">
                    <Button x:Name="TryAgainBtn"
                            Content="Try Again"
                            FontSize="11" Padding="14,6"
                            CornerRadius="12" />
                    <Button x:Name="CancelErrorBtn"
                            Content="Cancel"
                            FontSize="11" Padding="14,6"
                            CornerRadius="12" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
