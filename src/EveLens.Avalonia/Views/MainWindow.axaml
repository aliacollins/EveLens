<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EveLens.Avalonia.Views.CharacterMonitor"
        x:Class="EveLens.Avalonia.Views.MainWindow"
        Title="EveLens"
        Icon="avares://EveLens/Properties/EveLens.ico"
        Width="1024" Height="768">

    <DockPanel>
        <!-- Menu bar -->
        <Menu x:Name="MainMenu" DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem x:Name="AddCharMenuItem" Header="_Add Character" />
                <MenuItem x:Name="CreateBlankCharMenuItem" Header="Create _Blank Character" />
                <MenuItem x:Name="ManageCharsMenuItem" Header="_Manage Characters" />
                <Separator />
                <MenuItem x:Name="ManageGroupsMenuItem" Header="Manage _Groups" />
                <Separator />
                <MenuItem x:Name="RestoreSettingsMenuItem" Header="_Restore Settings" />
                <MenuItem x:Name="SaveSettingsMenuItem" Header="_Save Settings" />
                <MenuItem x:Name="ResetSettingsMenuItem" Header="Re_set Settings" />
                <Separator />
                <MenuItem x:Name="SettingsMenuItem" Header="_Settings" InputGesture="Ctrl+OemComma" />
                <Separator />
                <MenuItem x:Name="ExitMenuItem" Header="E_xit" InputGesture="Ctrl+Q" />
            </MenuItem>
            <MenuItem x:Name="PlansMenu" Header="_Plans">
                <MenuItem x:Name="NewPlanMenuItem" Header="_New Plan" InputGesture="Ctrl+N" />
                <MenuItem x:Name="ManagePlansMenuItem" Header="_Manage Plans" InputGesture="Ctrl+M" />
                <Separator />
                <MenuItem x:Name="ImportPlanMenuItem" Header="_Import Plan from File" />
                <MenuItem x:Name="CreateFromQueueMenuItem" Header="_Create Plan from Queue" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem x:Name="CharCompMenuItem" Header="_Character Comparison" />
                <MenuItem x:Name="SkillFarmMenuItem" Header="Skill _Farm Dashboard" />
                <MenuItem x:Name="SkillConstellationMenuItem" Header="Skill _Visualization" />
                <Separator />
                <MenuItem x:Name="ClearCacheMenuItem" Header="C_lear Cache" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem x:Name="CheckUpdatesMenuItem" Header="_Check for Updates" />
                <Separator />
                <MenuItem x:Name="UserGuideMenuItem" Header="_User Guide" />
                <MenuItem x:Name="ReportIssueMenuItem" Header="_Report Issue" />
                <Separator />
                <MenuItem x:Name="KeyboardShortcutsMenuItem" Header="_Keyboard Shortcuts" />
                <MenuItem x:Name="AboutMenuItem" Header="_About EveLens" />
            </MenuItem>
        </Menu>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="8,3"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0"
                ClipToBounds="False">
            <DockPanel ClipToBounds="False">
                <TextBlock x:Name="EveTimeText" Text="EVE Time: --:--" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveAccentSecondaryBrush}" />
                <TextBlock Text="  |  " FontSize="{DynamicResource EveFontBody}" Foreground="{StaticResource EveTextDisabledBrush}" />
                <TextBlock x:Name="ServerStatusText" Text="Server: Unknown" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
                <TextBlock Text="  |  " FontSize="{DynamicResource EveFontBody}" Foreground="{StaticResource EveTextDisabledBrush}" />
                <!-- Right-docked items (outermost first) -->
                <TextBlock DockPanel.Dock="Right" x:Name="EsiActivityText"
                           Text="" FontSize="{DynamicResource EveFontBody}" HorizontalAlignment="Right"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />

                <!-- Privacy mode flyout -->
                <Button x:Name="PrivacyBtn" DockPanel.Dock="Right"
                        ToolTip.Tip="Privacy mode — hide sensitive values for screenshots"
                        Padding="6,3" CornerRadius="12"
                        Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Center" Cursor="Hand">
                    <Button.Flyout>
                        <Flyout Placement="TopEdgeAlignedRight">
                            <Border Background="{StaticResource EveBackgroundMediumBrush}"
                                    BorderBrush="{StaticResource EveBorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="0" MinWidth="220">
                                <StackPanel>
                                    <!-- Header -->
                                    <Border Padding="12,8"
                                            BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Privacy Mode" FontSize="{DynamicResource EveFontSubheading}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource EveAccentPrimaryBrush}" />
                                    </Border>
                                    <!-- Category checkboxes -->
                                    <StackPanel Margin="12,6,12,4" Spacing="4">
                                        <CheckBox x:Name="PrivacyNameCb" Content="Character Name" FontSize="{DynamicResource EveFontBody}"
                                                  Foreground="{StaticResource EveTextPrimaryBrush}" />
                                        <CheckBox x:Name="PrivacyCorpCb" Content="Corp / Alliance" FontSize="{DynamicResource EveFontBody}"
                                                  Foreground="{StaticResource EveTextPrimaryBrush}" />
                                        <CheckBox x:Name="PrivacyBalanceCb" Content="ISK Balance" FontSize="{DynamicResource EveFontBody}"
                                                  Foreground="{StaticResource EveTextPrimaryBrush}" />
                                        <CheckBox x:Name="PrivacySkillPointsCb" Content="Skill Points" FontSize="{DynamicResource EveFontBody}"
                                                  Foreground="{StaticResource EveTextPrimaryBrush}" />
                                        <CheckBox x:Name="PrivacyTrainingCb" Content="Training Queue" FontSize="{DynamicResource EveFontBody}"
                                                  Foreground="{StaticResource EveTextPrimaryBrush}" />
                                        <CheckBox x:Name="PrivacyRemapsCb" Content="Remaps" FontSize="{DynamicResource EveFontBody}"
                                                  Foreground="{StaticResource EveTextPrimaryBrush}" />
                                    </StackPanel>
                                    <!-- Toggle All button -->
                                    <Border Padding="12,4,12,8"
                                            BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
                                        <Button x:Name="PrivacyToggleAllBtn" Content="Toggle All"
                                                FontSize="{DynamicResource EveFontSmall}" Padding="10,4" CornerRadius="12"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                Background="Transparent"
                                                Foreground="{StaticResource EveTextSecondaryBrush}"
                                                Margin="0,4,0,0" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                    <Panel>
                        <PathIcon x:Name="EyeOpenIcon" Width="14" Height="14"
                                  Foreground="{StaticResource EveTextSecondaryBrush}"
                                  Data="M12 4.5C7.305 4.5 3.308 7.305 1.5 12c1.808 4.695 5.805 7.5 10.5 7.5s8.692-2.805 10.5-7.5c-1.808-4.695-5.805-7.5-10.5-7.5zM12 17a5 5 0 110-10 5 5 0 010 10zm0-8a3 3 0 100 6 3 3 0 000-6z" />
                        <PathIcon x:Name="EyeSlashIcon" Width="14" Height="14"
                                  Foreground="{StaticResource EveAccentPrimaryBrush}"
                                  Data="M3.53 2.47a.75.75 0 00-1.06 1.06l18 18a.75.75 0 001.06-1.06l-3.18-3.18C19.87 15.77 21.38 14.04 22.5 12c-1.808-4.695-5.805-7.5-10.5-7.5-1.77 0-3.42.41-4.89 1.13L3.53 2.47zM12 9a3 3 0 012.76 4.18l-3.94-3.94A2.99 2.99 0 0112 9zm-7.4.44C5.84 8.04 7.37 6.94 9.08 6.3l-1.6-1.6C5.7 5.78 4.13 7.27 3 9.15c-.32.54-.62 1.12-.88 1.72.04.1.08.19.13.28.92 1.87 2.32 3.47 4.01 4.64l-1.5-1.5c-.96-.9-1.7-1.97-2.16-3.15a12.5 12.5 0 010-.7zM12 17c-1.1 0-2.14-.26-3.07-.72l-1.51-1.51A5 5 0 0017 12c0-.54-.09-1.06-.25-1.55l2.16 2.16c-.35.66-.78 1.28-1.27 1.84-.5.57-1.06 1.07-1.67 1.5A8.14 8.14 0 0112 17z"
                                  IsVisible="False" />
                    </Panel>
                </Button>

                <!-- Queue health clock icon with flyout -->
                <Button x:Name="QueueHealthBtn" DockPanel.Dock="Right"
                        Background="Transparent" BorderThickness="0"
                        Padding="8,0" VerticalAlignment="Center"
                        ClipToBounds="False"
                        Cursor="Hand" ToolTip.Tip="Queue Health"
                        Click="OnQueueHealthClick">
                    <Panel ClipToBounds="False">
                        <TextBlock Text="&#x23F1;" FontSize="{DynamicResource EveFontTitle}" VerticalAlignment="Center" />
                        <Border x:Name="QueueBadge" IsVisible="False"
                                Background="{StaticResource EveWarningYellowBrush}"
                                CornerRadius="7" MinWidth="14" Height="14"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="8,-4,-6,0" Padding="3,0">
                            <TextBlock x:Name="QueueBadgeText" Text="0" FontSize="{DynamicResource EveFontCaption}"
                                       Foreground="Black" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Panel>
                </Button>

                <!-- Notification bell with flyout -->
                <Button x:Name="NotificationBellBtn" DockPanel.Dock="Right"
                        Background="Transparent" BorderThickness="0"
                        Padding="8,0" VerticalAlignment="Center"
                        ClipToBounds="False"
                        Cursor="Hand" ToolTip.Tip="Activity Log">
                    <Button.Flyout>
                        <Flyout Placement="TopEdgeAlignedRight">
                            <Border Background="{StaticResource EveBackgroundMediumBrush}"
                                    BorderBrush="{StaticResource EveBorderBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="0" MinWidth="360" MaxHeight="480">
                                <DockPanel>
                                    <!-- Header -->
                                    <Border DockPanel.Dock="Top" Padding="12,8"
                                            BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <TextBlock Text="Activity Log" FontSize="{DynamicResource EveFontSubheading}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource EveAccentPrimaryBrush}" />
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                        HorizontalAlignment="Right" Spacing="6">
                                                <Button x:Name="MarkReadBtn" Content="Mark Read"
                                                        FontSize="{DynamicResource EveFontSmall}" Padding="8,2" CornerRadius="10"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource EveTextSecondaryBrush}" />
                                                <Button x:Name="ClearAllBtn" Content="Clear"
                                                        FontSize="{DynamicResource EveFontSmall}" Padding="8,2" CornerRadius="10"
                                                        Background="Transparent"
                                                        Foreground="{StaticResource EveTextSecondaryBrush}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                    <!-- Empty state -->
                                    <TextBlock x:Name="EmptyActivityText"
                                               Text="No recent activity"
                                               FontSize="{DynamicResource EveFontBody}" Foreground="{StaticResource EveTextDisabledBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="0,40" IsVisible="False" />
                                    <!-- Activity list -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="ActivityItems">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="12,6"
                                                            BorderBrush="{StaticResource EveBorderBrush}"
                                                            BorderThickness="0,0,0,1">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <StackPanel Spacing="2">
                                                                <TextBlock Text="{Binding Description}" FontSize="{DynamicResource EveFontBody}"
                                                                           Foreground="{Binding DescriptionBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip.Tip="{Binding Description}" />
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{Binding CharacterName}" FontSize="{DynamicResource EveFontSmall}"
                                                                               Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                                               IsVisible="{Binding HasCharacter}" />
                                                                    <TextBlock Text="{Binding CategoryDisplay}" FontSize="{DynamicResource EveFontSmall}"
                                                                               Foreground="{StaticResource EveTextDisabledBrush}" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding TimeAgo}" FontSize="{DynamicResource EveFontSmall}"
                                                                       Foreground="{StaticResource EveTextDisabledBrush}"
                                                                       VerticalAlignment="Top" Margin="8,0,0,0" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                    <!-- Bell icon with badge -->
                    <Panel ClipToBounds="False">
                        <TextBlock Text="&#x1F514;" FontSize="{DynamicResource EveFontTitle}" VerticalAlignment="Center" />
                        <Border x:Name="UnreadBadge" IsVisible="False"
                                Background="{StaticResource EveErrorRedBrush}"
                                CornerRadius="7" MinWidth="14" Height="14"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="8,-4,-6,0" Padding="3,0">
                            <TextBlock x:Name="UnreadCountText" Text="0" FontSize="{DynamicResource EveFontCaption}"
                                       Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Panel>
                </Button>

                <!-- Remaining space: next update countdown -->
                <TextBlock x:Name="NextUpdateText" Text="" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveWarningYellowBrush}" />
            </DockPanel>
        </Border>

        <!-- Character portrait strip -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource EveBackgroundDarkBrush}"
                BorderBrush="{StaticResource EveBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="0,3">
            <DockPanel>
                <!-- Overview button -->
                <Button x:Name="OverviewBtn" DockPanel.Dock="Left"
                        Classes="char-slot"
                        Width="56" Margin="4,0,2,0"
                        ToolTip.Tip="Character Overview">
                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                        <Border Width="36" Height="36"
                                Background="{StaticResource EveBackgroundMediumBrush}"
                                Classes="portrait-ring">
                            <TextBlock Text="&#x2630;" FontSize="{DynamicResource EveFontTitle}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource EveAccentPrimaryBrush}" />
                        </Border>
                        <TextBlock Text="Ovr" FontSize="{DynamicResource EveFontCaption}" MaxWidth="50"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource EveTextSecondaryBrush}"
                                   HorizontalAlignment="Center" Tag="SlotName" />
                    </StackPanel>
                </Button>

                <!-- Scroll left -->
                <Button x:Name="ScrollLeftBtn" DockPanel.Dock="Left"
                        Classes="strip-arrow"
                        ToolTip.Tip="Scroll left">
                    <TextBlock Text="&#x2039;" FontSize="{DynamicResource EveFontTitle}" FontWeight="Bold"
                               Foreground="{StaticResource EveTextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Button>

                <!-- Scroll right -->
                <Button x:Name="ScrollRightBtn" DockPanel.Dock="Right"
                        Classes="strip-arrow"
                        ToolTip.Tip="Scroll right">
                    <TextBlock Text="&#x203A;" FontSize="{DynamicResource EveFontTitle}" FontWeight="Bold"
                               Foreground="{StaticResource EveTextSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Button>

                <!-- Add character button -->
                <Button x:Name="AddCharStripBtn" DockPanel.Dock="Right"
                        Classes="char-slot"
                        Width="56" Margin="2,0,4,0"
                        ToolTip.Tip="Add Character">
                    <StackPanel Spacing="2" HorizontalAlignment="Center">
                        <Border Width="36" Height="36"
                                CornerRadius="4"
                                BorderThickness="1"
                                BorderBrush="{StaticResource EveTextDisabledBrush}"
                                Background="Transparent">
                            <TextBlock Text="+" FontSize="{DynamicResource EveFontTitle}" FontWeight="Light"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{StaticResource EveAccentPrimaryBrush}" />
                        </Border>
                        <TextBlock Text="Add" FontSize="{DynamicResource EveFontCaption}" MaxWidth="50"
                                   TextAlignment="Center"
                                   Foreground="{StaticResource EveTextDisabledBrush}"
                                   HorizontalAlignment="Center" Tag="SlotName" />
                    </StackPanel>
                </Button>

                <!-- Character strip scroll area (drag to scroll) -->
                <ScrollViewer x:Name="CharStripScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              Cursor="Hand">
                    <StackPanel x:Name="CharStrip" Orientation="Horizontal" Spacing="2" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Main content area -->
        <ContentControl x:Name="MainContent" />
    </DockPanel>
</Window>
