<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EveLens.Avalonia.Views.CharacterMonitor.CharacterMonitorHeader">

    <Border Background="{StaticResource EveBackgroundMediumBrush}"
            BorderBrush="{StaticResource EveBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="10,8">
        <Grid ColumnDefinitions="Auto,*">

            <!-- Column 0: Portrait + account status -->
            <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,12,0"
                        VerticalAlignment="Top">
                <!-- Portrait with account-status-colored border -->
                <Border x:Name="PortraitBorder"
                        Width="132" Height="132"
                        Background="{StaticResource EveBackgroundDarkestBrush}"
                        BorderThickness="2"
                        CornerRadius="2">
                    <Image x:Name="PortraitImage"
                           Width="128" Height="128"
                           Stretch="UniformToFill" />
                </Border>

                <!-- Account status + override flyout -->
                <Button x:Name="StatusOverrideBtn"
                        Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Center"
                        Padding="6,3" Cursor="Hand"
                        ToolTip.Tip="Click to change account status">
                    <StackPanel Spacing="0" HorizontalAlignment="Center">
                        <TextBlock x:Name="AccountStatusLabel"
                                   FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" Spacing="3"
                                    HorizontalAlignment="Center">
                            <TextBlock x:Name="OverrideModeLabel"
                                       FontSize="8.5"
                                       Foreground="{StaticResource EveTextDisabledBrush}" />
                            <TextBlock Text="&#x25BE;" FontSize="8"
                                       Foreground="{StaticResource EveTextDisabledBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                            <MenuItem x:Name="AutoDetectItem" Header="Auto-detect" />
                            <Separator />
                            <MenuItem x:Name="EmulateAlphaItem" Header="Emulate Alpha" />
                            <MenuItem x:Name="EmulateOmegaItem" Header="Emulate Omega" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>

            <!-- Column 1: Character info + inline stats -->
            <StackPanel Grid.Column="1" Spacing="1">
                <!-- Name -->
                <TextBlock Text="{Binding Name}"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource EveAccentPrimaryBrush}" />

                <!-- Race / Bloodline (hidden when unset) -->
                <TextBlock x:Name="RaceText" FontSize="11"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           IsVisible="False" />

                <!-- Balance (prominent) + change indicator -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1,0,2">
                    <TextBlock Text="{Binding BalanceText}"
                               FontSize="11.5" FontWeight="SemiBold"
                               Foreground="{StaticResource EveSuccessGreenBrush}" />
                    <TextBlock x:Name="BalanceChangeIndicator"
                               Text="{Binding BalanceChangeText}"
                               FontSize="10" FontWeight="SemiBold"
                               VerticalAlignment="Center">
                        <TextBlock.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.3" />
                            </Transitions>
                        </TextBlock.Transitions>
                    </TextBlock>
                </StackPanel>

                <!-- Corporation -->
                <TextBlock Text="{Binding CorporationName, StringFormat='Corporation: {0}'}"
                           FontSize="11" Foreground="{StaticResource EveTextSecondaryBrush}" />

                <!-- Alliance (always shown to prevent layout shift) -->
                <TextBlock x:Name="AllianceText"
                           FontSize="11" Foreground="{StaticResource EveTextSecondaryBrush}" />

                <!-- Security Status -->
                <TextBlock Text="{Binding SecurityStatusText}"
                           FontSize="11" Foreground="{StaticResource EveTextSecondaryBrush}" />

                <!-- Active Ship -->
                <TextBlock Text="{Binding ShipText}"
                           FontSize="11" Foreground="{StaticResource EveTextSecondaryBrush}" />

                <!-- Location + Docked status -->
                <TextBlock x:Name="LocationText"
                           FontSize="11" Foreground="{StaticResource EveSuccessGreenBrush}" />
                <TextBlock x:Name="DockedText"
                           FontSize="11" Foreground="{StaticResource EveTextSecondaryBrush}" />

                <!-- Inline stats line -->
                <Border BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0"
                        Margin="0,4,0,0" Padding="0,4,0,0">
                    <TextBlock x:Name="StatsLine" FontSize="10"
                               Foreground="{StaticResource EveTextDisabledBrush}" />
                </Border>
            </StackPanel>

        </Grid>
    </Border>
</UserControl>
