<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EveLens.Avalonia.Views.CharacterMonitor.CharacterSkillsView">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="10,7"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <Button x:Name="CollapseAllBtn" Content="Collapse All" FontSize="{DynamicResource EveFontBody}" Padding="10,4"
                            CornerRadius="12" Click="OnCollapseAll" />
                    <Button x:Name="ExpandAllBtn" Content="Expand All" FontSize="{DynamicResource EveFontBody}" Padding="10,4"
                            CornerRadius="12" Click="OnExpandAll" />
                    <ToggleButton x:Name="ShowAllToggle" FontSize="{DynamicResource EveFontBody}" Padding="10,4"
                                  Content="Trained Only" IsChecked="False"
                                  CornerRadius="12" Click="OnToggleShowAll" />
                    <Button x:Name="ExportCsvBtn" Content="Export CSV" FontSize="{DynamicResource EveFontBody}" Padding="10,4"
                            CornerRadius="12" Click="OnExportCsv" />
                </StackPanel>

                <Border CornerRadius="14"
                        Background="{StaticResource EveBackgroundDarkestBrush}"
                        BorderBrush="{StaticResource EveBorderBrush}"
                        BorderThickness="1" Padding="0"
                        MinWidth="240" MaxWidth="320">
                    <DockPanel>
                        <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                Content="&#x2715;" FontSize="{DynamicResource EveFontSmall}"
                                Background="Transparent" BorderThickness="0"
                                Padding="8,4" CornerRadius="0,14,14,0"
                                Click="OnClearFilter" IsVisible="False" />
                        <TextBox x:Name="FilterBox" Watermark="Search skills..."
                                 FontSize="{DynamicResource EveFontBody}" Padding="10,5"
                                 Background="Transparent" BorderThickness="0"
                                 TextChanged="OnFilterChanged" />
                    </DockPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Skill level breakdown strip — click a level to filter -->
        <Border DockPanel.Dock="Top" Padding="10,5"
                Background="{StaticResource EveBackgroundDarkBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <ToggleButton x:Name="AllSkillsBtn" Content="All Skills" IsChecked="True"
                              FontSize="9.5" Padding="8,3" CornerRadius="10"
                              Click="OnLevelFilterClicked" Tag="-3"
                              ToolTip.Tip="Show every published skill (trained and uninjected)" />
                <ToggleButton x:Name="AllTrainedBtn"
                              FontSize="9.5" Padding="8,3" CornerRadius="10"
                              Click="OnLevelFilterClicked" Tag="-1"
                              ToolTip.Tip="Show all trained skills (Level I through V plus injected)" />
                <ToggleButton x:Name="LevelVBtn" FontSize="9.5" Padding="8,3" CornerRadius="10"
                              Click="OnLevelFilterClicked" Tag="5"
                              ToolTip.Tip="Show only Level V skills" />
                <ToggleButton x:Name="LevelIVBtn" FontSize="9.5" Padding="8,3" CornerRadius="10"
                              Click="OnLevelFilterClicked" Tag="4"
                              ToolTip.Tip="Show only Level IV skills" />
                <ToggleButton x:Name="LevelIIIBtn" FontSize="9.5" Padding="8,3" CornerRadius="10"
                              Click="OnLevelFilterClicked" Tag="3"
                              ToolTip.Tip="Show only Level III skills" />
                <ToggleButton x:Name="LevelIIBtn" FontSize="9.5" Padding="8,3" CornerRadius="10"
                              Click="OnLevelFilterClicked" Tag="2"
                              ToolTip.Tip="Show only Level II skills" />
                <ToggleButton x:Name="LevelIBtn" FontSize="9.5" Padding="8,3" CornerRadius="10"
                              Click="OnLevelFilterClicked" Tag="1"
                              ToolTip.Tip="Show only Level I skills" />
                <ToggleButton x:Name="LevelZeroBtn" FontSize="9.5" Padding="8,3" CornerRadius="10"
                              Click="OnLevelFilterClicked" Tag="0"
                              ToolTip.Tip="Show only injected but untrained skills" />
                <ToggleButton x:Name="UntrainedBtn" FontSize="9.5" Padding="8,3" CornerRadius="10"
                              Click="OnLevelFilterClicked" Tag="-2"
                              ToolTip.Tip="Show skills not yet injected — what you can still learn" />
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="10,5"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Text="Skills: 0" FontSize="{DynamicResource EveFontBody}"
                       Foreground="{StaticResource EveTextSecondaryBrush}" />
        </Border>

        <!-- Virtualized flat tree with VirtualizingStackPanel -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="SkillItemsControl" HorizontalAlignment="Stretch">
                <ItemsControl.Styles>
                    <Style Selector="ItemsControl > ContentPresenter">
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
