<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:EveLens.Avalonia.Views.Shared"
             x:Class="EveLens.Avalonia.Views.CharacterMonitor.CharacterStandingsView">

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Standings is not enabled for this character."
                           FontSize="{DynamicResource EveFontSubheading}"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enable this to start fetching data from EVE Online."
                           FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Enable Standings"
                        FontSize="{DynamicResource EveFontBody}" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <Border x:Name="ScopePrompt" IsVisible="False" Padding="20">
            <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="ESI scope not authorized" FontSize="{DynamicResource EveFontTitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource EveTextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{DynamicResource EveTextDisabledBrush}" HorizontalAlignment="Center"
                           Text="This character was authenticated without the required scope.&#x0a;Re-authenticate from File &#x2192; Manage Characters to enable this feature." />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Padding="10,7"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- Right side: group selector + collapse/expand -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <TextBlock Text="Group by:" FontSize="{DynamicResource EveFontBody}" VerticalAlignment="Center"
                                   Foreground="{StaticResource EveTextSecondaryBrush}" />
                        <ComboBox x:Name="GroupByCombo" FontSize="{DynamicResource EveFontBody}" Padding="8,3"
                                  MinWidth="120" SelectedIndex="0"
                                  SelectionChanged="OnGroupByChanged">
                            <ComboBoxItem Content="No group" />
                            <ComboBoxItem Content="Group" />
                            <ComboBoxItem Content="Status" />
                        </ComboBox>
                        <Button Content="Collapse All" FontSize="{DynamicResource EveFontBody}" Padding="10,4"
                                CornerRadius="12" Click="OnCollapseAll" />
                        <Button Content="Expand All" FontSize="{DynamicResource EveFontBody}" Padding="10,4"
                                CornerRadius="12" Click="OnExpandAll" />
                    </StackPanel>

                    <!-- Left side: search with clear -->
                    <Border CornerRadius="14"
                            Background="{StaticResource EveBackgroundDarkestBrush}"
                            BorderBrush="{StaticResource EveBorderBrush}"
                            BorderThickness="1" Padding="0"
                            MinWidth="240" MaxWidth="320">
                        <DockPanel>
                            <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                    Content="&#x2715;" FontSize="{DynamicResource EveFontSmall}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="8,4" CornerRadius="0,14,14,0"
                                    Click="OnClearFilter"
                                    IsVisible="False" />
                            <TextBox x:Name="FilterBox"
                                     Watermark="Search standings..."
                                     FontSize="{DynamicResource EveFontBody}" Padding="10,5"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextChanged="OnFilterChanged" />
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Padding="10,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText" Text="Standings: 0" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </Border>

            <!-- Empty state + scrollable content overlap in Grid -->
            <Grid>
                <shared:EmptyState x:Name="EmptyState" IsVisible="False"
                                   Title="No standings found"
                                   Subtitle="This character has no standings, or none match the current filter" />

                <!-- Virtualized flat tree with VirtualizingStackPanel -->
                <ScrollViewer x:Name="MainScroller" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="StandingItemsControl" Margin="0"
                                  HorizontalAlignment="Stretch">
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl > ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </Panel>
</UserControl>
