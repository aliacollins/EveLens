<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:EveLens.Avalonia.Views.Shared"
             xmlns:converters="clr-namespace:EveLens.Avalonia.Converters"
             x:Class="EveLens.Avalonia.Views.CharacterMonitor.CharacterWalletJournalView">

    <UserControl.Resources>
        <converters:AmountColorConverter x:Key="AmountColor" />
    </UserControl.Resources>

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock x:Name="EnableTitle" Text="Wallet Journal is not enabled for this character."
                           FontSize="{DynamicResource EveFontSubheading}"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="EnableSubtext" Text="Enable this to start fetching data from EVE Online."
                           FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button x:Name="EnableBtn" Content="Enable Wallet Journal"
                        FontSize="{DynamicResource EveFontBody}" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <Border x:Name="ScopePrompt" IsVisible="False" Padding="20">
            <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="ScopeTitle" Text="ESI scope not authorized" FontSize="{DynamicResource EveFontTitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource EveTextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock x:Name="ScopeSubtext" TextWrapping="Wrap" TextAlignment="Center" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{DynamicResource EveTextDisabledBrush}" HorizontalAlignment="Center"
                           Text="This character was authenticated without the required scope.&#x0a;Re-authenticate from File → Manage Characters to enable this feature." />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Padding="10,7"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <Button x:Name="CollapseAllBtn" Content="Collapse All" FontSize="{DynamicResource EveFontBody}" Padding="10,4"
                                CornerRadius="12" Click="OnCollapseAll" />
                        <Button x:Name="ExpandAllBtn" Content="Expand All" FontSize="{DynamicResource EveFontBody}" Padding="10,4"
                                CornerRadius="12" Click="OnExpandAll" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <!-- Pill search bar -->
                        <Border CornerRadius="14"
                                Background="{StaticResource EveBackgroundDarkestBrush}"
                                BorderBrush="{StaticResource EveBorderBrush}"
                                BorderThickness="1" Padding="0"
                                MinWidth="240" MaxWidth="320">
                            <DockPanel>
                                <Button x:Name="ClearFilterButton"
                                        DockPanel.Dock="Right"
                                        Content="&#x2715;" FontSize="{DynamicResource EveFontSmall}"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="8,4" CornerRadius="0,14,14,0"
                                        IsVisible="False"
                                        Click="OnClearFilter" />
                                <TextBox x:Name="FilterBox"
                                         Watermark="Search journal..."
                                         Background="Transparent" BorderThickness="0"
                                         FontSize="{DynamicResource EveFontBody}" Padding="10,5"
                                         TextChanged="OnFilterTextChanged" />
                            </DockPanel>
                        </Border>

                        <!-- Type filter -->
                        <TextBlock Text="Type:" FontSize="{DynamicResource EveFontBody}" VerticalAlignment="Center"
                                   Foreground="{StaticResource EveTextSecondaryBrush}" />
                        <ComboBox x:Name="TypeFilterCombo" FontSize="{DynamicResource EveFontBody}"
                                  MinWidth="140" Padding="8,4"
                                  SelectionChanged="OnTypeFilterChanged" />

                        <!-- Grouping -->
                        <TextBlock Text="Group:" FontSize="{DynamicResource EveFontBody}" VerticalAlignment="Center"
                                   Foreground="{StaticResource EveTextSecondaryBrush}" />
                        <ComboBox x:Name="GroupingCombo" FontSize="{DynamicResource EveFontBody}"
                                  MinWidth="140" Padding="8,4"
                                  SelectionChanged="OnGroupingChanged" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Padding="10,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </Border>

            <Grid>
                <!-- Empty state -->
                <shared:EmptyState x:Name="EmptyState" IsVisible="False"
                                   Title="No journal entries"
                                   Subtitle="Wallet journal entries will appear here when available" />

                <!-- Grouped journal list with chevron headers -->
                <ScrollViewer x:Name="GroupedList" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="JournalGroupsList" Margin="0" HorizontalAlignment="Stretch">
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl > ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Group header: ▸ Name   count -->
                                    <Border Classes="group-header" HorizontalAlignment="Stretch"
                                            PointerPressed="OnGroupHeaderClicked">
                                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
                                            <TextBlock Grid.Column="0" Text="{Binding Chevron}"
                                                       FontSize="{DynamicResource EveFontBody}" Width="16"
                                                       Foreground="{StaticResource EveTextSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="{DynamicResource EveFontBody}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Text="{Binding CountText}"
                                                       FontSize="{DynamicResource EveFontSmall}"
                                                       Foreground="{StaticResource EveTextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="8,0" />
                                        </Grid>
                                    </Border>

                                    <!-- Journal entry rows -->
                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  HorizontalAlignment="Stretch"
                                                  IsVisible="{Binding IsExpanded}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel Orientation="Vertical" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="item-row" Padding="24,4,8,4"
                                                        Background="{StaticResource EveBackgroundDarkBrush}"
                                                        BorderBrush="{StaticResource EveBorderBrush}"
                                                        BorderThickness="0,0,0,0.5" HorizontalAlignment="Stretch">
                                                    <Grid ColumnDefinitions="140,*,130,130" HorizontalAlignment="Stretch">
                                                        <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat=\{0:yyyy-MM-dd HH:mm\}}"
                                                                   FontSize="{DynamicResource EveFontSmall}" Foreground="{StaticResource EveTextSecondaryBrush}"
                                                                   VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center" Margin="8,0">
                                                            <TextBlock Text="{Binding Type}" FontSize="{DynamicResource EveFontBody}"
                                                                       Foreground="{StaticResource EveTextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding Reason}" FontSize="{DynamicResource EveFontSmall}"
                                                                       Foreground="{StaticResource EveTextDisabledBrush}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat=\{0:N2\} ISK}"
                                                                   FontSize="{DynamicResource EveFontBody}" Foreground="{Binding AmountBrush}"
                                                                   TextAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <TextBlock Grid.Column="3" Text="{Binding Balance, StringFormat=\{0:N2\} ISK}"
                                                                   FontSize="{DynamicResource EveFontSmall}" Foreground="{StaticResource EveTextDisabledBrush}"
                                                                   TextAlignment="Right" VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </DockPanel>
    </Panel>
</UserControl>
