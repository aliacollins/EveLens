<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:EveLens.Avalonia.Views.Shared"
             x:Class="EveLens.Avalonia.Views.CharacterMonitor.CharacterMailMessagesView">

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Mail Messages is not enabled for this character."
                           FontSize="{DynamicResource EveFontSubheading}"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Enable this to start fetching data from EVE Online."
                           FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Enable Mail Messages"
                        FontSize="{DynamicResource EveFontBody}" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <Border x:Name="ScopePrompt" IsVisible="False" Padding="20">
            <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="ESI scope not authorized" FontSize="{DynamicResource EveFontTitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource EveTextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{DynamicResource EveTextDisabledBrush}" HorizontalAlignment="Center"
                           Text="This character was authenticated without the required scope.&#x0a;Re-authenticate from File → Manage Characters to enable this feature." />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
            <!-- Top bar: search + group selector -->
            <Border DockPanel.Dock="Top" Padding="10,7"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- Right side: group selector + collapse/expand -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <TextBlock Text="Group by:" FontSize="{DynamicResource EveFontBody}" VerticalAlignment="Center"
                                   Foreground="{StaticResource EveTextSecondaryBrush}" />
                        <ComboBox x:Name="GroupByCombo" FontSize="{DynamicResource EveFontBody}" Padding="8,3"
                                  MinWidth="100" SelectedIndex="0"
                                  SelectionChanged="OnGroupByChanged">
                            <ComboBoxItem Content="State" />
                            <ComboBoxItem Content="Sent Date" />
                            <ComboBoxItem Content="Sender" />
                            <ComboBoxItem Content="Subject" />
                            <ComboBoxItem Content="Recipient" />
                            <ComboBoxItem Content="Corp/Alliance" />
                        </ComboBox>
                        <Button Content="Collapse All" FontSize="{DynamicResource EveFontBody}" Padding="10,4"
                                CornerRadius="12" Click="OnCollapseAll" />
                        <Button Content="Expand All" FontSize="{DynamicResource EveFontBody}" Padding="10,4"
                                CornerRadius="12" Click="OnExpandAll" />
                    </StackPanel>

                    <!-- Left side: search with clear -->
                    <Border CornerRadius="14"
                            Background="{StaticResource EveBackgroundDarkestBrush}"
                            BorderBrush="{StaticResource EveBorderBrush}"
                            BorderThickness="1" Padding="0"
                            MinWidth="240" MaxWidth="320">
                        <DockPanel>
                            <Button x:Name="ClearFilterBtn" DockPanel.Dock="Right"
                                    Content="&#x2715;" FontSize="{DynamicResource EveFontSmall}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="8,4" CornerRadius="0,14,14,0"
                                    Click="OnClearFilter"
                                    IsVisible="False" />
                            <TextBox x:Name="FilterBox"
                                     Watermark="Search mail..."
                                     FontSize="{DynamicResource EveFontBody}" Padding="10,5"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextChanged="OnFilterChanged" />
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Padding="10,5"
                    Background="{StaticResource EveBackgroundMediumBrush}"
                    BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock x:Name="StatusText" Text="Mail: 0 messages" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextSecondaryBrush}" />
            </Border>

            <!-- Empty state -->
            <shared:EmptyState x:Name="EmptyState" IsVisible="False"
                               Title="No mail messages"
                               Subtitle="Mail messages from EVE Online will appear here" />

            <!-- Gmail-style split: mail list (left) + reading pane (right) -->
            <Grid ColumnDefinitions="*,8,*">

                <!-- Left: Mail list -->
                <ScrollViewer Grid.Column="0" x:Name="MailScroller"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="MailGroupsList" Margin="0"
                                  HorizontalAlignment="Stretch">
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl > ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Group header (hidden for flat "All Mail" view) -->
                                    <Border Classes="group-header" HorizontalAlignment="Stretch"
                                            PointerPressed="OnGroupHeaderClicked"
                                            IsVisible="{Binding ShowHeader}">
                                        <Grid ColumnDefinitions="Auto,*,Auto" HorizontalAlignment="Stretch">
                                            <TextBlock Grid.Column="0" Text="{Binding Chevron}"
                                                       FontSize="{DynamicResource EveFontBody}" Width="16"
                                                       Foreground="{StaticResource EveTextSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="{DynamicResource EveFontBody}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" Text="{Binding CountText}"
                                                       FontSize="{DynamicResource EveFontSmall}"
                                                       Foreground="{StaticResource EveTextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="8,0" />
                                        </Grid>
                                    </Border>

                                    <!-- Mail items in group -->
                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  HorizontalAlignment="Stretch"
                                                  IsVisible="{Binding IsExpanded}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel Orientation="Vertical" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="item-row"
                                                        Background="{StaticResource EveBackgroundDarkBrush}"
                                                        Padding="12,6,12,6"
                                                        BorderBrush="{StaticResource EveBorderBrush}"
                                                        BorderThickness="0,0,0,0.5"
                                                        HorizontalAlignment="Stretch"
                                                        Cursor="Hand"
                                                        PointerPressed="OnMailItemClicked">
                                                    <Border.Tag>
                                                        <Binding />
                                                    </Border.Tag>
                                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                                          RowDefinitions="Auto,Auto"
                                                          HorizontalAlignment="Stretch">
                                                        <!-- Row 0: [new dot] Sender — Subject [Date] -->
                                                        <StackPanel Grid.Row="0" Grid.Column="0"
                                                                    Orientation="Horizontal" Spacing="6">
                                                            <Ellipse Width="6" Height="6"
                                                                     Fill="{StaticResource EveAccentPrimaryBrush}"
                                                                     IsVisible="{Binding IsNew}"
                                                                     VerticalAlignment="Center" />
                                                            <TextBlock Text="{Binding SenderName}"
                                                                       FontSize="{DynamicResource EveFontBody}" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                                       VerticalAlignment="Center"
                                                                       MaxWidth="140"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Row="0" Grid.Column="2"
                                                                   Text="{Binding SentDateText}"
                                                                   FontSize="{DynamicResource EveFontSmall}"
                                                                   Foreground="{StaticResource EveTextSecondaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,0,0" />
                                                        <!-- Row 1: Subject with preview -->
                                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                                   Grid.ColumnSpan="3"
                                                                   Text="{Binding Subject}"
                                                                   FontSize="{DynamicResource EveFontSmall}"
                                                                   Foreground="{StaticResource EveTextSecondaryBrush}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,2,0,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Divider -->
                <Border Grid.Column="1" Width="1" Background="{StaticResource EveBorderBrush}"
                        HorizontalAlignment="Center" />

                <!-- Right: Reading pane -->
                <Border Grid.Column="2" Background="{StaticResource EveBackgroundDarkBrush}">
                    <Panel>
                        <!-- No mail selected state -->
                        <TextBlock x:Name="ReadingPanePlaceholder"
                                   Text="Select a mail to read"
                                   FontSize="{DynamicResource EveFontBody}"
                                   Foreground="{StaticResource EveTextDisabledBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <!-- Mail content -->
                        <DockPanel x:Name="ReadingPane" IsVisible="False">
                            <!-- Mail header with back button -->
                            <Border DockPanel.Dock="Top" Padding="16,12"
                                    Background="{StaticResource EveBackgroundMediumBrush}"
                                    BorderBrush="{StaticResource EveBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <StackPanel Spacing="4">
                                    <Button Content="&#x2190; Back to list"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource EveTextSecondaryBrush}"
                                            FontSize="{DynamicResource EveFontSmall}"
                                            Padding="0,2" Cursor="Hand"
                                            Click="OnBackToList" />
                                    <TextBlock x:Name="ReadingSubject"
                                               FontSize="{DynamicResource EveFontSubheading}" FontWeight="SemiBold"
                                               Foreground="{StaticResource EveTextPrimaryBrush}"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock x:Name="ReadingSender"
                                                   FontSize="{DynamicResource EveFontBody}"
                                                   Foreground="{StaticResource EveAccentPrimaryBrush}" />
                                        <TextBlock x:Name="ReadingDate"
                                                   FontSize="{DynamicResource EveFontSmall}"
                                                   Foreground="{StaticResource EveTextDisabledBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock x:Name="ReadingRecipients"
                                               FontSize="{DynamicResource EveFontSmall}"
                                               Foreground="{StaticResource EveTextDisabledBrush}" />
                                </StackPanel>
                            </Border>

                            <!-- Mail body -->
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="ReadingBody"
                                           Padding="16,12"
                                           FontSize="{DynamicResource EveFontBody}"
                                           Foreground="{StaticResource EveTextPrimaryBrush}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </DockPanel>
                    </Panel>
                </Border>
            </Grid>
        </DockPanel>
    </Panel>
</UserControl>
