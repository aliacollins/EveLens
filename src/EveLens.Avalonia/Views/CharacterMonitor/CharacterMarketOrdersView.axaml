<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EveLens.Avalonia.Views.CharacterMonitor.CharacterMarketOrdersView">

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock x:Name="EnableTitle" Text="Market Order Tracking is not enabled for this character."
                           FontSize="{DynamicResource EveFontSubheading}"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="EnableSubtext" Text="Enable this to start fetching data from EVE Online."
                           FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button x:Name="EnableBtn" Content="Enable Market Order Tracking"
                        FontSize="{DynamicResource EveFontBody}" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <Border x:Name="ScopePrompt" IsVisible="False" Padding="20">
            <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="ScopeTitle" Text="ESI scope not authorized" FontSize="{DynamicResource EveFontTitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource EveTextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock x:Name="ScopeSubtext" TextWrapping="Wrap" TextAlignment="Center" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{DynamicResource EveTextDisabledBrush}" HorizontalAlignment="Center"
                           Text="This character was authenticated without the required scope.&#x0a;Re-authenticate from File → Manage Characters to enable this feature." />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
        <!-- Filter bar -->
        <Border DockPanel.Dock="Top" Padding="8,4"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <DockPanel>
                <TextBlock x:Name="FilterLabel" Text="Filter:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="FilterBox"
                         Text="{Binding TextFilter, Mode=TwoWay}"
                         Watermark="Search market orders..."
                         MinWidth="200" />
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Padding="8,4"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock>
                <TextBlock.Text>
                    <MultiBinding StringFormat="Items: {0}">
                        <Binding Path="TotalItemCount" />
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
        </Border>

        <!-- Data grid -->
        <DataGrid x:Name="ItemsGrid"
                  ItemsSource="{Binding Items}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="0">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy Item Name" />
                    <MenuItem Header="Copy Station" />
                    <Separator />
                    <MenuItem Header="Export to CSV..." />
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Item" Binding="{Binding Item.Name}" Width="200" />
                <DataGridTextColumn Header="Station" Binding="{Binding Station.Name}" Width="200" />
                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitaryPrice, StringFormat=\{0:N2\} ISK}" Width="120" />
                <DataGridTextColumn Header="Total Price" Binding="{Binding TotalPrice, StringFormat=\{0:N2\} ISK}" Width="120" />
                <DataGridTextColumn Header="Initial Vol" Binding="{Binding InitialVolume}" Width="80" />
                <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingVolume}" Width="80" />
                <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="70" />
                <DataGridTextColumn Header="Issued" Binding="{Binding Issued, StringFormat=\{0:yyyy-MM-dd\}}" Width="100" />
                <DataGridTextColumn Header="Expires" Binding="{Binding Expiration, StringFormat=\{0:yyyy-MM-dd\}}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>
        </DockPanel>
    </Panel>
</UserControl>
