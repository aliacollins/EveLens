<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EveLens.Avalonia.Views.CharacterMonitor.CharacterEmploymentHistoryView">

    <Panel>
        <!-- Enable prompt shown when endpoint is not yet activated -->
        <Border x:Name="EnablePrompt" IsVisible="False"
                Background="{StaticResource EveBackgroundDarkBrush}"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock x:Name="EnableTitle" Text="Employment History is not enabled for this character."
                           FontSize="{DynamicResource EveFontSubheading}"
                           Foreground="{StaticResource EveTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="EnableSubtext" Text="Enable this to start fetching data from EVE Online."
                           FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <Button x:Name="EnableBtn" Content="Enable Employment History"
                        FontSize="{DynamicResource EveFontBody}" Padding="16,6" CornerRadius="12"
                        HorizontalAlignment="Center"
                        Click="OnEnableEndpoint" />
            </StackPanel>
        </Border>

        <Border x:Name="ScopePrompt" IsVisible="False" Padding="20">
            <StackPanel Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="ScopeTitle" Text="ESI scope not authorized" FontSize="{DynamicResource EveFontTitle}" FontWeight="SemiBold"
                           Foreground="{DynamicResource EveTextSecondaryBrush}" HorizontalAlignment="Center" />
                <TextBlock x:Name="ScopeSubtext" TextWrapping="Wrap" TextAlignment="Center" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{DynamicResource EveTextDisabledBrush}" HorizontalAlignment="Center"
                           Text="This character was authenticated without the required scope.&#x0a;Re-authenticate from File → Manage Characters to enable this feature." />
            </StackPanel>
        </Border>

        <DockPanel x:Name="DataContent">
        <!-- Status bar with view toggle -->
        <Border DockPanel.Dock="Bottom" Padding="10,5"
                Background="{StaticResource EveBackgroundMediumBrush}"
                BorderBrush="{StaticResource EveBorderBrush}" BorderThickness="0,1,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                    <ToggleButton x:Name="TimelineViewBtn" Content="Timeline" IsChecked="True"
                                  FontSize="{DynamicResource EveFontSmall}" Padding="8,3" CornerRadius="10"
                                  Click="OnViewToggle" />
                    <ToggleButton x:Name="ListViewBtn" Content="List"
                                  FontSize="{DynamicResource EveFontSmall}" Padding="8,3" CornerRadius="10"
                                  Click="OnViewToggle" />
                </StackPanel>
                <TextBlock x:Name="StatusText" Text="Records: 0" FontSize="{DynamicResource EveFontBody}"
                           Foreground="{StaticResource EveTextSecondaryBrush}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Both views in a Panel so DockPanel gives full remaining space -->
        <Panel>
        <!-- Vertical list view — card-row style -->
        <ListBox x:Name="ListItems" IsVisible="False"
                 Background="Transparent" BorderThickness="0"
                 Margin="12,8"
                 HorizontalAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,4" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource EveBackgroundMediumBrush}"
                                CornerRadius="6" Padding="12,10"
                                BorderBrush="{StaticResource EveBorderBrush}"
                                BorderThickness="0.5"
                                HorizontalAlignment="Stretch">
                            <Grid ColumnDefinitions="40,*,Auto,Auto" HorizontalAlignment="Stretch">
                                <!-- Corp initial circle -->
                                <Border Grid.Column="0" Width="34" Height="34"
                                        CornerRadius="17"
                                        Background="{StaticResource EveBackgroundDarkestBrush}"
                                        VerticalAlignment="Center">
                                    <Border Width="34" Height="34" CornerRadius="17"
                                            Background="{StaticResource EveBackgroundDarkestBrush}"
                                            BorderBrush="{StaticResource EveBorderBrush}"
                                            BorderThickness="1" ClipToBounds="True">
                                        <Image Width="34" Height="34" Stretch="UniformToFill" />
                                    </Border>
                                </Border>

                                <!-- Corp name + date range -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding CorporationName}"
                                               FontSize="{DynamicResource EveFontBody}" FontWeight="SemiBold"
                                               Foreground="{StaticResource EveAccentPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="{DynamicResource EveFontSmall}"
                                               Foreground="{StaticResource EveTextDisabledBrush}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:yyyy-MM-dd} → {1}">
                                                <Binding Path="StartDate" />
                                                <Binding Path="EndDateText" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Duration badge -->
                                <Border Grid.Column="2" CornerRadius="10"
                                        Background="{StaticResource EveBackgroundDarkestBrush}"
                                        Padding="10,4" VerticalAlignment="Center" Margin="8,0">
                                    <TextBlock Text="{Binding DurationText}"
                                               FontSize="{DynamicResource EveFontSmall}"
                                               Foreground="{StaticResource EveTextSecondaryBrush}" />
                                </Border>

                                <!-- Current indicator -->
                                <Border Grid.Column="3" CornerRadius="10"
                                        Padding="8,4" VerticalAlignment="Center"
                                        IsVisible="{Binding IsCurrent}">
                                    <Border.Background>
                                        <SolidColorBrush Color="#2054D878" />
                                    </Border.Background>
                                    <TextBlock Text="Current" FontSize="{DynamicResource EveFontSmall}"
                                               Foreground="{StaticResource EveSuccessGreenBrush}"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        <!-- Horizontal timeline (drag or wheel to scroll) -->
        <ScrollViewer x:Name="TimelineScroller"
                      HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Disabled"
                      VerticalAlignment="Center"
                      Cursor="Hand">
            <Grid RowDefinitions="Auto,Auto,Auto" Margin="20,16"
                  HorizontalAlignment="Left">

                <!-- Row 0: Corp cards -->
                <ItemsControl x:Name="TimelineItems" Grid.Row="0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Width="160" Margin="0,0,4,0">
                                <!-- Corp card -->
                                <Border Background="{StaticResource EveBackgroundMediumBrush}"
                                        BorderBrush="{StaticResource EveBorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="8,6" MinHeight="70"
                                        HorizontalAlignment="Stretch">
                                    <StackPanel Spacing="3" HorizontalAlignment="Center">
                                        <!-- Corp logo placeholder -->
                                        <Border Width="32" Height="32"
                                                Background="{StaticResource EveBackgroundDarkestBrush}"
                                                BorderBrush="{StaticResource EveBorderBrush}"
                                                BorderThickness="1" CornerRadius="2"
                                                HorizontalAlignment="Center">
                                            <Image Width="32" Height="32" Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Text="{Binding CorporationName}"
                                                   FontSize="{DynamicResource EveFontSmall}" FontWeight="SemiBold"
                                                   Foreground="{StaticResource EveAccentPrimaryBrush}"
                                                   TextAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" MaxWidth="136"
                                                   ToolTip.Tip="{Binding CorporationName}" />
                                        <TextBlock Text="{Binding DurationText}"
                                                   FontSize="{DynamicResource EveFontCaption}"
                                                   Foreground="{StaticResource EveTextDisabledBrush}"
                                                   TextAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <!-- Connector dot -->
                                <Ellipse Width="8" Height="8"
                                         Fill="{StaticResource EveAccentPrimaryBrush}"
                                         HorizontalAlignment="Center"
                                         Margin="0,4,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Row 1: Horizontal timeline bar -->
                <Border Grid.Row="1" Height="2"
                        Background="{StaticResource EveAccentDimmedBrush}"
                        Margin="0,0,0,0" />

                <!-- Row 2: Date labels -->
                <ItemsControl x:Name="DateLabels" Grid.Row="2">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Width="164">
                                <!-- Up tick -->
                                <Border Width="1" Height="6"
                                        Background="{StaticResource EveAccentDimmedBrush}"
                                        HorizontalAlignment="Center" />
                                <!-- Date + Duration -->
                                <TextBlock Text="{Binding StartDate, StringFormat='{}{0:MMM yyyy}'}"
                                           FontSize="{DynamicResource EveFontSmall}"
                                           Foreground="{StaticResource EveTextSecondaryBrush}"
                                           TextAlignment="Center" />
                                <TextBlock Text="{Binding DurationText}"
                                           FontSize="{DynamicResource EveFontCaption}"
                                           Foreground="{StaticResource EveTextDisabledBrush}"
                                           TextAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>
        </ScrollViewer>
        </Panel>
        </DockPanel>
    </Panel>
</UserControl>
